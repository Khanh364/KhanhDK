local RedzLib = loadstring(game:HttpGet("https://raw.githubusercontent.com/RHEZAKUN/RedzLib/main/Source.lua"))()

local Window = RedzLib:MakeWindow({
    Title = "Khanh Hub - DuyKhanh V6",
    SubTitle = "Sửa Lỗi Không Hiện Menu",
    HeaderColor = Color3.fromRGB(255, 0, 0)
})

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

local cfg = { speed = 16, jump = 50, aura = false, infj = false }

local Tab = Window:CreateTab("Main", "home")

Tab:AddToggle("Kill Aura + Fast Attack", false, function(v)
    cfg.aura = v
end)

Tab:AddSlider("Speed", 16, 500, 16, function(v)
    cfg.speed = v
end)

Tab:AddSlider("Jump", 50, 1000, 50, function(v)
    cfg.jump = v
end)

Tab:AddToggle("Infinite Jump", false, function(v)
    cfg.infj = v
end)

-- Logic vận hành (Chống văng, chống lỗi)
RunService.Stepped:Connect(function()
    pcall(function()
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            local hum = LocalPlayer.Character.Humanoid
            hum.WalkSpeed = cfg.speed
            hum.JumpPower = cfg.jump
            hum.UseJumpPower = true
            
            if cfg.aura then
                local tool = LocalPlayer.Character:FindFirstChildOfClass("Tool")
                if tool then
                    tool:Activate()
                    for _, v in pairs(tool:GetDescendants()) do
                        if v:IsA("RemoteEvent") then v:FireServer() end
                    end
                end
            end
        end
    end)
end)

game:GetService("UserInputService").JumpRequest:Connect(function()
    if cfg.infj and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
    end
end)
