getgenv().Config = { 
    FastAttack = true, 
    AimLock = true, 
    MaxDistAim = 90,
    Prediction = 0.14,
    SmoothFactor = 0.25
}

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Camera = workspace.CurrentCamera
local LP = Players.LocalPlayer

pcall(function()
    local Shaker = require(game.ReplicatedStorage.Util.CameraShaker)
    if Shaker then Shaker:Stop() end
end)

local function SetOwner(char)
    pcall(function()
        char:WaitForChild("HumanoidRootPart"):SetNetworkOwner(LP)
    end)
end
LP.CharacterAdded:Connect(SetOwner)
if LP.Character then SetOwner(LP.Character) end

task.spawn(function()
    while task.wait() do
        if getgenv().Config.FastAttack then
            pcall(function()
                for _, v in pairs(getreg()) do
                    if typeof(v) == "function" and getfenv(v).script and getfenv(v).script.Name == "CombatFramework" then
                        for _, v2 in pairs(debug.getupvalues(v)) do
                            if typeof(v2) == "table" and v2.activeController then
                                v2.activeController.timeToNextAttack = 0
                                v2.activeController.attacking = false
                                v2.activeController.hitboxMagnitude = 55
                                v2.activeController.increment = 3
                            end
                        end
                    end
                end
            end)
        end
    end
end)

local aiming = false
local target = nil

local function GetClosest()
    local closest, minDist = nil, getgenv().Config.MaxDistAim
    local myRoot = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end
    
    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LP and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local hum = plr.Character:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 and (not plr.Team or plr.Team ~= LP.Team) then
                local _, onScreen = Camera:WorldToViewportPoint(plr.Character.HumanoidRootPart.Position)
                if onScreen then
                    local dist = (myRoot.Position - plr.Character.HumanoidRootPart.Position).Magnitude
                    if dist < minDist then
                        minDist = dist
                        closest = plr
                    end
                end
            end
        end
    end
    return closest
end

UserInputService.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton2 and getgenv().Config.AimLock then
        aiming = true
        target = GetClosest()
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton2 then
        aiming = false
        target = nil
    end
end)

RunService.RenderStepped:Connect(function()
    if aiming and target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = target.Character.HumanoidRootPart
        local predictPos = hrp.Position + (hrp.Velocity * getgenv().Config.Prediction)
        local lookAt = CFrame.lookAt(Camera.CFrame.Position, predictPos)
        Camera.CFrame = Camera.CFrame:Lerp(lookAt, getgenv().Config.SmoothFactor)
    end
end)

task.spawn(function()
    while task.wait(60) do
        game:GetService("VirtualUser"):CaptureController()
        game:GetService("VirtualUser"):ClickButton1(Vector2.new(0,0))
    end
end)
