local RigController = nil
local function GetRigController()
    if RigController then return RigController end
    pcall(function()
        RigController = require(LP.PlayerScripts:WaitForChild("CombatFramework"):WaitForChild("RigController"))
    end)
    return RigController
end

RunService.Stepped:Connect(function()
    if getgenv().Config.FastAttack then
        pcall(function()
            local combat = GetRigController()
            if combat then
                combat.timeToNextAttack = 0
                combat.attacking = false
                combat.hitboxMagnitude = 60
                combat.increment = 4
                combat.blocking = false
            end
        end)
    end
    
    if getgenv().Config.NoClip and LP.Character then
        for _, v in pairs(LP.Character:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end

    if getgenv().Config.AntiStun and LP.Character then
        pcall(function()
            local hum = LP.Character:FindFirstChild("Humanoid")
            if hum then
                hum.PlatformStand = false
            end
            for _, v in pairs(LP.Character:GetDescendants()) do
                if v:IsA("BodyVelocity") or v:IsA("BodyPosition") or v:IsA("BodyAngularVelocity") or v:IsA("BodyGyro") then
                    v:Destroy()
                end
            end
        end)
    end
end)

local currentTarget = nil

local function GetClosest()
    local closest, minDist = nil, getgenv().Config.MaxDistAim
    local myRoot = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end
    
    for _, plr in pairs(Players:GetPlayers()) do
        if plr \~= LP and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local hum = plr.Character:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 and (not plr.Team or plr.Team \~= LP.Team) then
                local _, onScreen = Camera:WorldToViewportPoint(plr.Character.HumanoidRootPart.Position)
                if onScreen then
                    local dist = (myRoot.Position - plr.Character.HumanoidRootPart.Position).Magnitude
                    if dist < minDist then
                        minDist = dist
                        closest = plr
                    end
                end
            end
        end
    end
    return closest
end

RunService.RenderStepped:Connect(function()
    if getgenv().Config.AutoAim then
        currentTarget = GetClosest()
        
        if currentTarget and currentTarget.Character then
            local targetRoot = currentTarget.Character:FindFirstChild("HumanoidRootPart")
            local targetHum = currentTarget.Character:FindFirstChild("Humanoid")
            
            if targetHum and targetHum.Health > 0 and targetRoot then
                local myRoot = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
                local predictPos = targetRoot.Position + (targetRoot.Velocity * getgenv().Config.Prediction)
                
                Camera.CFrame = Camera.CFrame:Lerp(CFrame.lookAt(Camera.CFrame.Position, predictPos), getgenv().Config.SmoothFactor)
                
                if getgenv().Config.AutoFace and myRoot then
                    myRoot.CFrame = CFrame.lookAt(myRoot.Position, Vector3.new(predictPos.X, myRoot.Position.Y, predictPos.Z))
                end
            end
        end
    end
end)

