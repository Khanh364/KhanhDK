local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local workspace = game:GetService("Workspace")
local lighting = game:GetService("Lighting")

getgenv().Config = {
    FastAttack = true,
    AttackSpeed = 0.1,
    HitboxSize = 50,
    HitboxTransparency = 0.8,
    PlayerESP = true,
    Noclip = true,
    AntiSit = true,
    WalkOnWater = true,
    RemoveEffects = true,
    AutoFace = true
}

local CombatFramework
pcall(function()
    CombatFramework = require(LocalPlayer.PlayerScripts.CombatFramework)
end)

local function GetCurrentController()
    if CombatFramework then
        return CombatFramework.activeController
    end
    return nil
end

local function Attack()
    local controller = GetCurrentController()
    if controller and controller.equipped then
        pcall(function()
            controller:attack() 
        end)
    end
end

local function Optimize()
    lighting.GlobalShadows = false
    lighting.Brightness = 1
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and not v:IsDescendantOf(LocalPlayer.Character) then
            v.Material = Enum.Material.SmoothPlastic
        elseif v:IsA("Decal") or v:IsA("ParticleEmitter") or v:IsA("Trail") then
            if getgenv().Config.RemoveEffects then v:Destroy() end
        end
    end
end
Optimize()

local function ApplyESP(plr)
    if plr ~= LocalPlayer and plr.Character and not plr.Character:FindFirstChild("ESPHighlight") then
        local highlight = Instance.new("Highlight")
        highlight.Name = "ESPHighlight"
        highlight.Parent = plr.Character
        highlight.FillColor = Color3.new(1, 0, 0)
        highlight.FillTransparency = 0.5
    end
end

local function GetNearestTarget()
    local target = nil
    local dist = 500
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") and v.Character.Humanoid.Health > 0 then
            local d = (v.Character.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
            if d < dist then
                dist = d
                target = v.Character.HumanoidRootPart
            end
        end
    end
    return target
end

local waterPart = Instance.new("Part")
waterPart.Size = Vector3.new(100, 5, 100)
waterPart.Anchored = true
waterPart.Transparency = 1
waterPart.Parent = workspace

RunService.RenderStepped:Connect(function()
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local myHrp = LocalPlayer.Character.HumanoidRootPart
        
        -- Walk on Water
        if getgenv().Config.WalkOnWater then
            waterPart.Position = Vector3.new(myHrp.Position.X, 13.5, myHrp.Position.Z)
        else
            waterPart.Position = Vector3.new(0, -999, 0)
        end

        -- Hitbox & ESP
        for _, plr in pairs(Players:GetPlayers()) do
            if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
                local hrp = plr.Character.HumanoidRootPart
                if plr.Character.Humanoid.Health > 0 then
                    hrp.Size = Vector3.new(getgenv().Config.HitboxSize, getgenv().Config.HitboxSize, getgenv().Config.HitboxSize)
                    hrp.Transparency = getgenv().Config.HitboxTransparency
                    hrp.BrickColor = BrickColor.new("Really red")
                    hrp.Material = Enum.Material.Neon
                    hrp.CanCollide = false
                    if getgenv().Config.PlayerESP then ApplyESP(plr) end
                else
                    hrp.Size = Vector3.new(2, 2, 1)
                    hrp.Transparency = 1
                end
            end
        end

        -- Auto Face
        if getgenv().Config.AutoFace then
            local target = GetNearestTarget()
            if target then
                myHrp.CFrame = CFrame.new(myHrp.Position, Vector3.new(target.Position.X, myHrp.Position.Y, target.Position.Z))
            end
        end
    end
end)

RunService.Stepped:Connect(function()
    if getgenv().Config.Noclip and LocalPlayer.Character then
        for _, v in pairs(LocalPlayer.Character:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end
end)

task.spawn(function()
    while true do
        if getgenv().Config.FastAttack then
            Attack()
        end
        if getgenv().Config.AntiSit and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
            LocalPlayer.Character.Humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, false)
        end
        task.wait(getgenv().Config.AttackSpeed)
    end
end)
