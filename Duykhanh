-- Farm Tab
local FarmTab = Window:NewTab("Auto Farm")
local FarmSection = FarmTab:NewSection("Main Farm")

FarmSection:NewToggle("Auto Farm Level/Quest", "", function(s)
    getgenv().Config.AutoFarmLevel = s
    spawn(function()
        while getgenv().Config.AutoFarmLevel do
            pcall(function()
                local q = GetQuestInfo()
                TeleportTo(q.QuestPos)
                wait(1)
                CommF_:InvokeServer("StartQuest", q.QuestName, q.QuestLevel)
                repeat wait(0.5) until not Player.PlayerGui.Main.Quest.Visible -- Wait quest complete
                while getgenv().Config.AutoFarmLevel do
                    local e = GetClosestEnemy(q.EnemyName)
                    if e then AttackEnemy(e); wait(0.3) else break end
                end
            end)
            wait(2)
        end
    end)
end)

