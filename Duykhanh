RunService.RenderStepped:Connect(function()
   if not aimbotEnabled then return end
   local target = getClosestPlayer(aimbotFOV)
   if target and target.Character then
      local part = target.Character:FindFirstChild(aimbotPart)
      if part then
         local prediction = _G.AimPrediction or 0
         local hrp = target.Character:FindFirstChild("HumanoidRootPart")
         local targetPos = part.Position
         if prediction > 0 and hrp then
            targetPos = targetPos + hrp.Velocity * prediction * 0.016
         end
         Camera.CFrame = Camera.CFrame:Lerp(
            CFrame.new(Camera.CFrame.Position, targetPos),
            1 / aimbotSmooth
         )
      end
   end
end)

