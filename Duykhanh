local FlySection = MiscTab:NewSection("Movement")
FlySection:NewToggle("Fly (Z)", "", function(s)
    getgenv().Config.FlyEnabled = s
    if s then
        local bg = Instance.new("BodyVelocity", HumanoidRootPart)
        bg.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        bg.Velocity = Vector3.new()
        repeat
            bg.Velocity = Workspace.CurrentCamera.CFrame.LookVector * getgenv().Config.FlySpeed
            if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.Z) then
                getgenv().Config.FlyEnabled = false
                break
            end
            wait()
        until not getgenv().Config.FlyEnabled
        bg:Destroy()
    end
end)

