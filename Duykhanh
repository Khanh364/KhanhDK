getgenv().Config = { 
    FastAttack = true, 
    AimLock = true, 
    MaxDistAim = 90,
    Prediction = 0.14,
    SmoothFactor = 0.35
}

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Camera = workspace.CurrentCamera
local LP = Players.LocalPlayer

local StopCamera = require(game.ReplicatedStorage.Util.CameraShaker)
StopCamera:Stop()

pcall(sethiddenproperty, LP, "SimulationRadius", 1000)
LP.ReplicationFocus = workspace

spawn(function()
    RunService.Heartbeat:Connect(function()
        pcall(function()
            local char = LP.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                char.HumanoidRootPart:SetNetworkOwner(LP)
                for _, obj in pairs(char:GetChildren()) do
                    if obj:IsA("Tool") and obj:FindFirstChild("Handle") then
                        obj.Handle:SetNetworkOwner(LP)
                    end
                end
            end
        end)
    end)
end)

for _, v in pairs(getreg()) do
    if typeof(v) == "function" and getfenv(v).script == LP.PlayerScripts:FindFirstChild("CombatFramework") then
        for _, v2 in pairs(debug.getupvalues(v)) do
            if typeof(v2) == "table" then
                spawn(function()
                    RunService.RenderStepped:Connect(function()
                        if getgenv().Config.FastAttack then
                            pcall(function()
                                v2.activeController.timeToNextAttack = math.random(-1.0, -0.15)
                                v2.activeController.attacking = false
                                v2.activeController.increment = 2.2
                                v2.activeController.blocking = false
                                v2.activeController.hitboxMagnitude = 55
                                v2.activeController.humanoid.AutoRotate = true
                                v2.activeController.focusStart = 0
                            end)
                        end
                    end)
                end)
            end
        end
    end
end

local aiming = false
local target = nil

local function GetClosest()
    local closest, minDist = nil, getgenv().Config.MaxDistAim
    local myRoot = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")
    if not myRoot then return nil end
    local myPos = myRoot.Position
    
    for _, plr in pairs(Players:GetPlayers()) do
        if plr \~= LP and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local hum = plr.Character:FindFirstChild("Humanoid")
            if hum and hum.Health > 0 and (not plr.Team or plr.Team \~= LP.Team) then
                local dist = (myPos - plr.Character.HumanoidRootPart.Position).Magnitude
                if dist < minDist then
                    minDist = dist
                    closest = plr
                end
            end
        end
    end
    return closest
end

UserInputService.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 and getgenv().Config.AimLock then
        aiming = true
        target = GetClosest()
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        aiming = false
        target = nil
    end
end)

RunService.RenderStepped:Connect(function()
    if aiming and target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
        local hrp = target.Character.HumanoidRootPart
        local predictPos = hrp.Position + (hrp.Velocity * getgenv().Config.Prediction)
        local targetCFrame = CFrame.new(Camera.CFrame.Position, predictPos)
        Camera.CFrame = Camera.CFrame:Lerp(targetCFrame, getgenv().Config.SmoothFactor)
    end
end)

spawn(function()
    while task.wait(120) do
        game:GetService("VirtualUser"):CaptureController()
        game:GetService("VirtualUser"):ClickButton1(Vector2.new())
    end
end)
