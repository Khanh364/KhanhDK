local function GetQuestInfo()
    local level = Player.Data.Level.Value
    if level < 15 then return QuestData[1]
    elseif level < 30 then return QuestData[2]
    elseif level < 40 then return QuestData[3]
    elseif level < 60 then return QuestData[4]
    elseif level < 90 then return QuestData[5]
    elseif level < 120 then return QuestData[6]
    elseif level < 150 then return QuestData[7]
    elseif level < 700 then return QuestData[8]
    else return QuestData[10] end
end

local function TeleportTo(cf)
    if Character and HumanoidRootPart then
        HumanoidRootPart.CFrame = cf * CFrame.new(0, 5, 0)
    end
end

local function AttackEnemy(enemy)
    if enemy and enemy:FindFirstChild("HumanoidRootPart") and enemy.Humanoid.Health > 0 then
        TeleportTo(enemy.HumanoidRootPart.CFrame)
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, true, game, 1)
        wait(0.1)
        VirtualInputManager:SendMouseButtonEvent(0, 0, 0, false, game, 1)
    end
end

local function GetClosestEnemy(name)
    local closest, dist = nil, math.huge
    for _, e in pairs(Workspace.Enemies:GetChildren()) do
        if e.Name == name and e:FindFirstChild("Humanoid") and e.Humanoid.Health > 0 then
            local d = (HumanoidRootPart.Position - e.HumanoidRootPart.Position).Magnitude
            if d < dist then closest, dist = e, d end
        end
    end
    return closest
end

local FarmTab = Window:NewTab("Auto Farm")
local FarmSection = FarmTab:NewSection("Farm")

FarmSection:NewToggle("Auto Farm Level", "", function(s)
    getgenv().Config.AutoFarmLevel = s
    spawn(function()
        while getgenv().Config.AutoFarmLevel do
            pcall(function()
                local q = GetQuestInfo()
                if q then
                    TeleportTo(q.QuestPos)
                    wait(1)
                    CommF_:InvokeServer("StartQuest", q.QuestName, q.QuestLevel)
                    while getgenv().Config.AutoFarmLevel do
                        local e = GetClosestEnemy(q.EnemyName)
                        if e then
                            AttackEnemy(e)
                            wait(0.3)
                        else break end
                    end
                end
            end)
            wait(2)
        end
    end)
end)

FarmSection:NewToggle("Auto Farm Boss", "", function(s)
    getgenv().Config.AutoFarmBoss = s
    spawn(function()
        while getgenv().Config.AutoFarmBoss do
            pcall(function()
                for _, boss in pairs({"The Gorilla King", "Yeti", "Vice Admiral"}) do
                    local b = Workspace.Enemies:FindFirstChild(boss)
                    if b and b.Humanoid.Health > 0 then
                        TeleportTo(b.HumanoidRootPart.CFrame)
                        repeat
                            AttackEnemy(b)
                            wait(0.5)
                        until b.Humanoid.Health <= 0 or not getgenv().Config.AutoFarmBoss
                        break
                    end
                end
            end)
            wait(5)
        end
    end)
end)

