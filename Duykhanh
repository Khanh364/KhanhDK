-- Farm Logic Basic (Auto Farm Level + Settings)
local FarmLoop
local function startFarm()
    spawn(function()
        while getgenv().Config.AutoFarmLevel do
            pcall(function()
                -- Tìm quest NPC gần nhất (ví dụ: ví dụ generic, bạn có thể chỉnh tên NPC)
                local questNPC = workspace.NPCs:FindFirstChildWhichIsA("Model") -- Thay bằng tên quest cụ thể nếu biết
                if questNPC and questNPC:FindFirstChild("ClickDetector") then
                    if getgenv().Config.BypassTP then
                        getHRP().CFrame = questNPC.HumanoidRootPart.CFrame * CFrame.new(0,0,-3)
                    end
                    fireclickdetector(questNPC.ClickDetector)
                end
                
                -- Tìm mob gần (pathfind đến mob)
                local mob = workspace.Enemies:FindFirstChildWhichIsA("Model") -- Lọc mob quest
                if mob and mob:FindFirstChild("Humanoid") and mob.Humanoid.Health > 0 then
                    local path = PathfindingService:CreatePath()
                    path:ComputeAsync(getHRP().Position, mob.HumanoidRootPart.Position)
                    if path.Status == Enum.PathStatus.Success then
                        for _, waypoint in pairs(path:GetWaypoints()) do
                            getHum():MoveTo(waypoint.Position)
                            task.wait(0.1)
                        end
                    end
                    if getgenv().Config.BringMob then
                        mob.HumanoidRootPart.CFrame = getHRP().CFrame * CFrame.new(0,0,-5) -- Bring về
                    end
                    -- Attack (hold M1 simulate)
                    if getgenv().Config.FastAttack then toggleFastAttack(true) end -- Tích hợp fast attack
                end
                task.wait(getgenv().Config.FarmDelay)
            end)
            task.wait()
        end
    end)
end

local function toggleAutoFarm(v)
    getgenv().Config.AutoFarmLevel = v
    if v then startFarm() end
end

