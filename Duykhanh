-- Tab 3: Mobile Skills (Dành riêng cho điện thoại)
local Tab3 = Window:CreateTab("Mobile Skills", "smartphone")

Tab3:CreateToggle({
   Name = "Auto Spam Skills (Z, X, C, V)",
   CurrentValue = false,
   Callback = function(Value)
      autoSkillEnabled = Value
      if Value then
         task.spawn(function()
            while autoSkillEnabled do
               local keys = {Enum.KeyCode.Z, Enum.KeyCode.X, Enum.KeyCode.C, Enum.KeyCode.V}
               for _, key in ipairs(keys) do
                  if not autoSkillEnabled then break end
                  VIM:SendKeyEvent(true, key, false, game)
                  task.wait(0.05)
                  VIM:SendKeyEvent(false, key, false, game)
                  task.wait(0.3) -- Nghỉ giữa các chiêu
               end
            end
         end)
      end
   end,
})

