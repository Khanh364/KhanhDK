-- Functions chung
local function getChar() return lp.Character or lp.CharacterAdded:Wait() end
local function getHRP() local char = getChar() return char:WaitForChild("HumanoidRootPart") end
local function getHum() local char = getChar() return char:WaitForChild("Humanoid") end

-- Fast Attack (Bypass 2026 - VIM simulate click + fallback hook)
local FastAttackConn
local function toggleFastAttack(v)
    getgenv().Config.FastAttack = v
    if FastAttackConn then FastAttackConn:Disconnect() end
    if v then
        FastAttackConn = RS.Heartbeat:Connect(function()
            VIM:SendMouseButtonEvent(0, 0, 0, true, game, 1)
            task.wait(0.01)
            VIM:SendMouseButtonEvent(0, 0, 0, false, game, 1)
        end)
    end
end

-- God Mode (Auto heal + bypass damage)
local GodConn
local function toggleGodMode(v)
    getgenv().Config.GodMode = v
    if GodConn then GodConn:Disconnect() end
    if v then
        GodConn = RS.Heartbeat:Connect(function()
            local hum = getHum()
            if hum then
                hum.Health = hum.MaxHealth
                hum.PlatformStand = true
                task.wait(0.05)
                hum.PlatformStand = false
            end
        end)
    end
end

-- Fly (Misc - Mượt 2026)
local FlyConn, BV, BG
local function toggleFly(v)
    getgenv().Config.Fly = v
    local hrp = getHRP()
    local hum = getHum()
    if v then
        BV = Instance.new("BodyVelocity", hrp); BV.MaxForce = Vector3.new(4000, 4000, 4000); BV.Velocity = Vector3.new(0, 0.1, 0)
        BG = Instance.new("BodyGyro", hrp); BG.MaxTorque = Vector3.new(4000, 4000, 4000); BG.CFrame = hrp.CFrame
        FlyConn = RS.Heartbeat:Connect(function()
            if not getgenv().Config.Fly then return end
            local cam = workspace.CurrentCamera
            local move = hum.MoveDirection * 50
            BV.Velocity = cam.CFrame:VectorToWorldSpace(move)
            if UIS:IsKeyDown(Enum.KeyCode.Space) then BV.Velocity += Vector3.new(0, 50, 0) end
            if UIS:IsKeyDown(Enum.KeyCode.LeftShift) then BV.Velocity -= Vector3.new(0, 50, 0) end
        end)
    else
        if FlyConn then FlyConn:Disconnect() end
        if BV then BV:Destroy() end
        if BG then BG:Destroy() end
    end
end

-- Noclip (Misc)
local NoclipConn
local function toggleNoclip(v)
    getgenv().Config.Noclip = v
    if NoclipConn then NoclipConn:Disconnect() end
    if v then
        NoclipConn = RS.Stepped:Connect(function()
            local char = getChar()
            for _, part in pairs(char:GetChildren()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end)
    end
end

-- Infinite Jump (Misc)
local InfJumpConn
local function toggleInfJump(v)
    getgenv().Config.InfJump = v
    if InfJumpConn then InfJumpConn:Disconnect() end
    if v then
        InfJumpConn = UIS.JumpRequest:Connect(function() getHum():ChangeState("Jumping") end)
    end
end

-- Fullbright (Misc)
local function toggleFullbright(v)
    getgenv().Config.Fullbright = v
    if v then
        Lighting.Brightness = 2
        Lighting.ClockTime = 14
        Lighting.FogEnd = 9e9
        Lighting.GlobalShadows = false
        Lighting.OutdoorAmbient = Color3.fromRGB(128, 128, 128)
    else
        Lighting.Brightness = 1
        Lighting.ClockTime = 14
        Lighting.FogEnd = 100000
        Lighting.GlobalShadows = true
        Lighting.OutdoorAmbient = Color3.fromRGB(50, 50, 50)
    end
end

-- Apply Stats (Misc)
local function applyStats()
    local hum = getHum()
    hum.WalkSpeed = getgenv().Config.WalkSpeed
    hum.JumpPower = getgenv().Config.JumpPower
    hum.HipHeight = getgenv().Config.HipHeight
end

-- Auto Farm Level (Farm - Basic strong loop 2026)
local FarmConn
local function toggleAutoFarmLevel(v)
    getgenv().Config.AutoFarmLevel = v
    if FarmConn then FarmConn:Disconnect() end
    if v then
        FarmConn = RS.Heartbeat:Connect(function()
            pcall(function()
                local enemies = workspace.Enemies:GetChildren()
                for _, enemy in pairs(enemies) do
                    if enemy:IsA("Model") and enemy:FindFirstChild("Humanoid") and enemy.Humanoid.Health > 0 then
                        local path = PathfindingService:CreatePath()
                        path:ComputeAsync(getHRP().Position, enemy.HumanoidRootPart.Position)
                        if path.Status == Enum.PathStatus.Success then
                            for _, waypoint in pairs(path:GetWaypoints()) do
                                getHum():MoveTo(waypoint.Position)
                                task.wait(0.05)
                            end
                        end
                        if getgenv().Config.BringMob then
                            enemy.HumanoidRootPart.CFrame = getHRP().CFrame * CFrame.new(0, 0, -5)
                        end
                        if getgenv().Config.FastAttack then toggleFastAttack(true) end
                        if getgenv().Config.BypassTP then
                            getHRP().CFrame = enemy.HumanoidRootPart.CFrame * CFrame.new(0, 5, -3)
                        end
                        break -- Farm 1 mob at a time
                    end
                end
            end)
            task.wait(getgenv().Config.FarmDelay)
        end)
    end
end

