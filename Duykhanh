local function TweenToCFrame(cf)
    if not RootPart then return end
    local Tween = TweenService:Create(RootPart, TweenInfo.new(0.5, Enum.EasingStyle.Linear), {CFrame = cf})
    Tween:Play()
end

local function GetNearestMob()
    local dist = math.huge
    local target = nil
    for _, mob in pairs(Workspace.Enemies:GetChildren()) do
        local hum = mob:FindFirstChild("Humanoid")
        local hrp = mob:FindFirstChild("HumanoidRootPart")
        if hum and hum.Health > 0 and hrp then
            local d = (RootPart.Position - hrp.Position).Magnitude
            if d < dist and d < 1000 then dist = d; target = mob end
        end
    end
    return target
end

local function AttackMob(mob)
    if not mob or not mob:FindFirstChild("HumanoidRootPart") then return end
    TweenToCFrame(mob.HumanoidRootPart.CFrame * CFrame.new(0, 5, -8)) -- đứng sau mob
    task.wait(0.1)
    -- Dùng remote attack (phổ biến hơn ở update mới, thay tool:Activate)
    pcall(function()
        ReplicatedStorage.Remotes.CommF_:InvokeServer("Melee", mob.Humanoid)
        ReplicatedStorage.Remotes.CommF_:InvokeServer("KenHaki", true)
    end)
end

local function HopServer()
    local servers = game:GetService("HttpService"):JSONDecode(game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100"))
    for _, v in pairs(servers.data) do
        if v.playing < v.maxPlayers and v.playing > 5 then -- tránh server rỗng
            TeleportService:TeleportToPlaceInstance(game.PlaceId, v.id)
            break
        end
    end
end

local function ToggleFly(state)
    Flying = state
    if not RootPart then return end
    if Flying then
        local BV = Instance.new("BodyVelocity", RootPart)
        BV.MaxForce = Vector3.new(1e5, 1e5, 1e5)
        BV.Velocity = Vector3.new()
        local BG = Instance.new("BodyGyro", RootPart)
        BG.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
        BG.P = 1e5
        spawn(function()
            while Flying and RootPart do
                local cam = Workspace.CurrentCamera
                BV.Velocity = cam.CFrame.LookVector * FlySpeed
                BG.CFrame = cam.CFrame
                task.wait()
            end
            BV:Destroy()
            BG:Destroy()
        end)
    end
end

