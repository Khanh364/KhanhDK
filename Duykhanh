local hopCfg = getgenv().Config.AutoServerHop

if hopCfg.Enable then
    task.spawn(function()
        local TS = game:GetService("TeleportService")
        
        while true do
            task.wait(hopCfg.CheckInterval)
            
            if not LP.Character or not LP.Character:FindFirstChild("HumanoidRootPart") then continue end
            
            local playerCount = #Players:GetPlayers() - 1
            
            if playerCount < hopCfg.MinPlayers then
                ReplicatedStorage.DefaultChatSystemChatEvents.SayMessageRequest:FireServer("Auto hopping server vắng...", "All")
                
                task.wait(hopCfg.HopDelay)
                
                playerCount = #Players:GetPlayers() - 1
                if playerCount < hopCfg.MinPlayers then
                    local success, err = pcall(function()
                        TS:Teleport(game.PlaceId, LP)
                    end)
                    
                    if not success then
                        if hopCfg.RetryIfFail then task.wait(5) end
                    end
                end
            end
        end
    end)
end
