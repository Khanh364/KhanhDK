-- LOGIC HỆ THỐNG (Giữ nguyên các tính năng PVP Hardcore của bạn)
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local ReplicatedStorage = game:GetService("ReplicatedStorage")

-- Aim Skill Hook
local Mouse = LocalPlayer:GetMouse()
local oldIndex
oldIndex = hookmetamethod(game, "__index", function(self, index)
    if skillAim and self == Mouse and (index == "Hit" or index == "Target") then
        local target = nil
        local dist = 250
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local magnitude = (p.Character.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                if magnitude < dist then dist = magnitude target = p end
            end
        end
        if target then return index == "Hit" and target.Character.HumanoidRootPart.CFrame or target.Character.HumanoidRootPart end
    end
    return oldIndex(self, index)
end)

-- Anti-Kick
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    if getnamecallmethod() == "Kick" then return nil end
    return oldNamecall(self, ...)
end)

