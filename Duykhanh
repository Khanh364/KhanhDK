Tabs.Misc:AddSlider("JP", {Title = "Jump Power", Min = 50, Max = 500, Default = 50, Rounding = 0}):OnChanged(function(V) jumpPower = V end)
Tabs.Misc:AddToggle("WaterWalk", {Title = "Walk on Water", Default = false}):OnChanged(function(V) waterWalk = V end)
Tabs.Misc:AddToggle("FakeLag", {Title = "Fake Lag", Default = false}):OnChanged(function(V) fakeLag = V end)

RunService.Stepped:Connect(function()
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("Humanoid") then
        char.Humanoid.WalkSpeed = walkSpeed
        char.Humanoid.JumpPower = jumpPower
        if waterWalk and char:FindFirstChild("HumanoidRootPart") then
            if char.HumanoidRootPart.Position.Y < 1 then
                char.HumanoidRootPart.Velocity = Vector3.new(char.HumanoidRootPart.Velocity.X, 0, char.HumanoidRootPart.Velocity.Z)
                char.HumanoidRootPart.CFrame = char.HumanoidRootPart.CFrame * CFrame.new(0, 0.5, 0)
            end
        end
    end
    settings().Network.IncomingReplicationLag = fakeLag and 1000 or 0
end)

task.spawn(function()
    while task.wait(0.1) do
        pcall(function()
            if autoHaki then
                if not LocalPlayer.Character:FindFirstChild("HasBuso") then
                    ReplicatedStorage.Remotes.CommF_:InvokeServer("Buso")
                end
                game:GetService("VirtualInputManager"):SendKeyEvent(true, Enum.KeyCode.E, false, game)
            end
            if autoV4 then ReplicatedStorage.Remotes.CommF_:InvokeServer("ActivateTransformation") end
            if fastAttack then
                local target = getClosestPlayer()
                if target and target.Character and (LocalPlayer.Character.HumanoidRootPart.Position - target.Character.HumanoidRootPart.Position).Magnitude <= 40 then
                    ReplicatedStorage.Remotes.CommF_:InvokeServer("Attack", target.Character.HumanoidRootPart)
                end
            end
        end)
    end
end)

