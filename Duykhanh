local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Khanh Hub - ULTIMATE EDITION",
   Icon = "award",
   LoadingTitle = "Skibidi DK - Full Power",
   LoadingSubtitle = "Phiên bản Full Chức Năng",
   Theme = "Pear",
   ConfigurationSaving = { Enabled = true, FolderName = "KhanhHub", FileName = "FullConfig" }
})

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local silentAimEnabled = false
local killAuraEnabled = false
local fastAttackEnabled = false
local noSlowdownEnabled = false
local infJumpEnabled = false
local noclipEnabled = false
local antiStunEnabled = false
local walkSpeed = 16
local jumpPower = 50
local silentAimFOV = 150

local function getChar() return LocalPlayer.Character end
local function getHum() return getChar() and getChar():FindFirstChildWhichIsA("Humanoid") end
local function getHRP() return getChar() and getChar():FindFirstChild("HumanoidRootPart") end

local Tab1 = Window:CreateTab("Bounty Hunter", "crosshair")

Tab1:CreateToggle({
   Name = "Silent Aim (Ngắm ngầm)",
   CurrentValue = false,
   Callback = function(Value) silentAimEnabled = Value end,
})

Tab1:CreateToggle({
   Name = "Fast Attack (Đánh siêu tốc)",
   CurrentValue = false,
   Callback = function(Value)
      fastAttackEnabled = Value
      task.spawn(function()
         while fastAttackEnabled do
            local tool = getChar() and getChar():FindFirstChildWhichIsA("Tool")
            if tool then tool:Activate() end
            task.wait(0.001)
         end
      end)
   end,
})

Tab1:CreateButton({
   Name = "Áp sát mục tiêu gần nhất",
   Callback = function()
      local target = nil
      local dist = math.huge
      for _, p in ipairs(Players:GetPlayers()) do
         if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local d = (p.Character.HumanoidRootPart.Position - getHRP().Position).Magnitude
            if d < dist then dist = d target = p.Character end
         end
      end
      if target then
         getHRP().CFrame = target.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3)
      end
   end,
})

local Tab2 = Window:CreateTab("Combat", "sword")

Tab2:CreateToggle({
   Name = "Kill Aura (Tầm xa)",
   CurrentValue = false,
   Callback = function(Value) killAuraEnabled = Value end,
})

Tab2:CreateToggle({
   Name = "Anti-Stun (Chống choáng/khựng)",
   CurrentValue = false,
   Callback = function(Value) antiStunEnabled = Value end,
})

Tab2:CreateToggle({
   Name = "No Slowdown (Không giảm tốc)",
   CurrentValue = false,
   Callback = function(Value) noSlowdownEnabled = Value end,
})

local Tab3 = Window:CreateTab("Movement", "zap")

Tab3:CreateSlider({
   Name = "Tốc độ chạy",
   Range = {16, 500},
   Increment = 5,
   CurrentValue = 16,
   Callback = function(Value) walkSpeed = Value end,
})

Tab3:CreateSlider({
   Name = "Độ cao nhảy",
   Range = {50, 1000},
   Increment = 10,
   CurrentValue = 50,
   Callback = function(Value) jumpPower = Value end,
})

Tab3:CreateToggle({
   Name = "Nhảy vô hạn (Inf Jump)",
   CurrentValue = false,
   Callback = function(Value) infJumpEnabled = Value end,
})

Tab3:CreateToggle({
   Name = "Xuyên tường (Noclip)",
   CurrentValue = false,
   Callback = function(Value) noclipEnabled = Value end,
})

UserInputService.JumpRequest:Connect(function()
   if infJumpEnabled then
      local hum = getHum()
      if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
   end
end)

RunService.Heartbeat:Connect(function()
   local char = getChar()
   if not char or not getHRP() then return end
   local tool = char:FindFirstChildWhichIsA("Tool")
   
   local target = nil
   local dist_f = silentAimFOV
   for _, p in ipairs(Players:GetPlayers()) do
      if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
         local pos, onScreen = Camera:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
         if onScreen then
            local d = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
            if d < dist_f then dist_f = d target = p.Character end
         end
      end
   end

   if target and tool then
      local tHRP = target.HumanoidRootPart
      local dist = (tHRP.Position - getHRP().Position).Magnitude
      
      if (silentAimEnabled or killAuraEnabled) and dist <= 30 then
         for _, r in ipairs(tool:GetDescendants()) do
            if r:IsA("RemoteEvent") then
               r:FireServer(tHRP.Position)
               r:FireServer(target)
            end
         end
      end
   end
end)

RunService.Stepped:Connect(function()
   local char = getChar()
   if not char then return end
   
   if noclipEnabled then
      for _, p in ipairs(char:GetDescendants()) do
         if p:IsA("BasePart") then p.CanCollide = false end
      end
   end
   
   local hum = getHum()
   if hum then
      hum.WalkSpeed = walkSpeed
      hum.JumpPower = jumpPower
      hum.UseJumpPower = true
      
      if antiStunEnabled or noSlowdownEnabled then
         hum.PlatformStand = false
         if hum:GetState() == Enum.HumanoidStateType.Ragdoll then
            hum:ChangeState(Enum.HumanoidStateType.GettingUp)
         end
      end
   end
end)

Rayfield:Notify({
   Title = "Khanh Hub",
   Content = "Script Loaded!",
   Duration = 6,
   Image = "award"
})
