local OrionLib = loadstring(game:HttpGet('https://raw.githubusercontent.com/jannypanda/OrionLib-Mobile/main/Source.lua'))()

local Window = OrionLib:MakeWindow({
    Name = "Khanh Hub - 2026 Mobile", 
    HidePremium = false, 
    SaveConfig = true, 
    ConfigFolder = "KhanhConfig",
    IntroText = "Khanh Hub Loading..."
})

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local silentAimEnabled = false
local killAuraEnabled = false
local fastAttackEnabled = false
local noSlowdownEnabled = false
local infJumpEnabled = false
local noclipEnabled = false
local antiStunEnabled = false
local walkSpeed = 16
local jumpPower = 50
local silentAimFOV = 150

local function getChar() return LocalPlayer.Character end
local function getHum() return getChar() and getChar():FindFirstChildWhichIsA("Humanoid") end
local function getHRP() return getChar() and getChar():FindFirstChild("HumanoidRootPart") end

local Tab1 = Window:MakeTab({
    Name = "Bounty Hunter",
    Icon = "rbxassetid://4483345998",
    PremiumOnly = false
})

Tab1:AddToggle({
    Name = "Silent Aim",
    Default = false,
    Callback = function(Value) silentAimEnabled = Value end
})

Tab1:AddToggle({
    Name = "Fast Attack",
    Default = false,
    Callback = function(Value)
        fastAttackEnabled = Value
        task.spawn(function()
            while fastAttackEnabled do
                local tool = getChar() and getChar():FindFirstChildWhichIsA("Tool")
                if tool then tool:Activate() end
                task.wait(0.01)
            end
        end)
    end
})

Tab1:AddButton({
    Name = "Áp sát mục tiêu",
    Callback = function()
        local target = nil
        local dist = math.huge
        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                local d = (p.Character.HumanoidRootPart.Position - getHRP().Position).Magnitude
                if d < dist then dist = d target = p.Character end
            end
        end
        if target then getHRP().CFrame = target.HumanoidRootPart.CFrame * CFrame.new(0, 0, 3) end
    end
})

local Tab2 = Window:MakeTab({
    Name = "Combat",
    Icon = "rbxassetid://4483362458",
    PremiumOnly = false
})

Tab2:AddToggle({ Name = "Kill Aura", Default = false, Callback = function(Value) killAuraEnabled = Value end })
Tab2:AddToggle({ Name = "Anti-Stun", Default = false, Callback = function(Value) antiStunEnabled = Value end })
Tab2:AddToggle({ Name = "No Slowdown", Default = false, Callback = function(Value) noSlowdownEnabled = Value end })

local Tab3 = Window:MakeTab({
    Name = "Movement",
    Icon = "rbxassetid://4483362748",
    PremiumOnly = false
})

Tab3:AddSlider({ Name = "Speed", Min = 16, Max = 500, Default = 16, Increment = 1, Callback = function(V) walkSpeed = V end })
Tab3:AddSlider({ Name = "Jump", Min = 50, Max = 1000, Default = 50, Increment = 1, Callback = function(V) jumpPower = V end })
Tab3:AddToggle({ Name = "Inf Jump", Default = false, Callback = function(V) infJumpEnabled = V end })
Tab3:AddToggle({ Name = "Noclip", Default = false, Callback = function(V) noclipEnabled = V end })

UserInputService.JumpRequest:Connect(function()
   if infJumpEnabled then
      local hum = getHum()
      if hum then hum:ChangeState(Enum.HumanoidStateType.Jumping) end
   end
end)

RunService.Heartbeat:Connect(function()
   local char = getChar()
   if not char or not getHRP() then return end
   local tool = char:FindFirstChildWhichIsA("Tool")
   
   local target = nil
   local dist_f = silentAimFOV
   for _, p in ipairs(Players:GetPlayers()) do
      if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
         local pos, onScreen = Camera:WorldToViewportPoint(p.Character.HumanoidRootPart.Position)
         if onScreen then
            local d = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
            if d < dist_f then dist_f = d target = p.Character end
         end
      end
   end

   if target and tool and (silentAimEnabled or killAuraEnabled) then
      local tHRP = target.HumanoidRootPart
      if (tHRP.Position - getHRP().Position).Magnitude <= 30 then
         for _, r in ipairs(tool:GetDescendants()) do
            if r:IsA("RemoteEvent") then r:FireServer(tHRP.Position) r:FireServer(target) end
         end
      end
   end
end)

RunService.Stepped:Connect(function()
   local char = getChar()
   if not char then return end
   if noclipEnabled then
      for _, p in ipairs(char:GetDescendants()) do if p:IsA("BasePart") then p.CanCollide = false end end
   end
   local hum = getHum()
   if hum then
      hum.WalkSpeed = walkSpeed
      hum.JumpPower = jumpPower
      hum.UseJumpPower = true
      if antiStunEnabled or noSlowdownEnabled then
         hum.PlatformStand = false
         if hum:GetState() == Enum.HumanoidStateType.Ragdoll then hum:ChangeState(Enum.HumanoidStateType.GettingUp) end
      end
   end
end)

OrionLib:Init()
