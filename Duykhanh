-- Fast Attack Hook
local mt = getrawmetatable(game)
local oldNamecall = mt.__namecall
setreadonly(mt, false)
mt.__namecall = newcclosure(function(self, ...)
    if Config.FastAttack and getnamecallmethod() == "FireServer" and self.Name == "MeleeDamage" then
        for i = 1, 5 do oldNamecall(self, ...) end
    end
    return oldNamecall(self, ...)
end)
setreadonly(mt, true)

-- Utility Functions
local function FireCommF(action, ...)
    pcall(function() RS.Remotes.CommF_:InvokeServer(action, ...) end)
end

local function TeleTo(cframe)
    if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
        lp.Character.HumanoidRootPart.CFrame = cframe
    end
end

