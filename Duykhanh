local RedzLib = loadstring(game:HttpGet("https://raw.githubusercontent.com/RHEZAKUN/RedzLib/main/Source.lua"))()

local Window = RedzLib:MakeWindow({
    Title = "Khanh Hub - V3 (Logic Optimized)",
    SubTitle = "Fixed for Mobile 2026",
    HeaderColor = Color3.fromRGB(255, 50, 50)
})

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- Variables
local silentAimEnabled = false
local killAuraEnabled = false
local fastAttackEnabled = false
local walkSpeed = 16
local jumpPower = 50

-- Hàm tìm đối thủ gần nhất (Fix lỗi nhận diện)
local function getClosestPlayer()
    local target = nil
    local dist = 30 -- Tầm đánh 30 studs
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") and p.Character:FindFirstChild("Humanoid").Health > 0 then
            local d = (p.Character.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
            if d < dist then
                dist = d
                target = p.Character
            end
        end
    end
    return target
end

-- TAB 1: PVP LOGIC (Đã sửa lại hoàn toàn)
local Tab1 = Window:CreateTab("Bounty Hunter", "target")

Tab1:AddToggle("Silent Aim + Kill Aura", false, function(Value)
    killAuraEnabled = Value
    silentAimEnabled = Value
end)

Tab1:AddToggle("Fast Attack (Super Speed)", false, function(Value)
    fastAttackEnabled = Value
end)

-- TAB 2: MOVEMENT
local Tab2 = Window:CreateTab("Movement", "zap")
Tab2:AddSlider("Tốc độ", 16, 500, 16, function(V) walkSpeed = V end)
Tab2:AddSlider("Nhảy cao", 50, 1000, 50, function(V) jumpPower = V end)
Tab2:AddToggle("Nhảy vô hạn", false, function(V) _G.InfJ = V end)

-- [VÒNG LẶP XỬ LÝ CHÍNH - ĐÃ KIỂM TRA]
RunService.RenderStepped:Connect(function()
    local char = LocalPlayer.Character
    if not char then return end
    
    -- Fix Speed & Jump (Ép chỉ số liên tục)
    local hum = char:FindFirstChildOfClass("Humanoid")
    if hum then
        hum.WalkSpeed = walkSpeed
        hum.JumpPower = jumpPower
        hum.UseJumpPower = true
    end

    -- Fix Fast Attack & Kill Aura
    if fastAttackEnabled or killAuraEnabled then
        local target = getClosestPlayer()
        local tool = char:FindFirstChildOfClass("Tool")
        
        if target and tool then
            -- 1. Kích hoạt đòn đánh client
            tool:Activate()
            
            -- 2. Ép sát thương lên Server (Quét Remote)
            for _, v in pairs(tool:GetDescendants()) do
                if v:IsA("RemoteEvent") then
                    -- Gửi dữ liệu tới vị trí địch
                    v:FireServer(target.HumanoidRootPart.Position)
                    v:FireServer(target)
                end
            end
        end
    end
end)

-- Fix Nhảy vô hạn
game:GetService("UserInputService").JumpRequest:Connect(function()
    if _G.InfJ and LocalPlayer.Character:FindFirstChildOfClass("Humanoid") then
        LocalPlayer.Character:FindFirstChildOfClass("Humanoid"):ChangeState(Enum.HumanoidStateType.Jumping)
    end
end)

print("Khanh Hub V3: Logic Checked & Loaded")
