local function GetQuestInfo()
    local level = Player:FindFirstChild("Data") and Player.Data:FindFirstChild("Level") and Player.Data.Level.Value or 1
    for _, q in pairs(QuestData) do
        if level >= q.Min and level <= q.Max then return q end
    end
    return QuestData[1] -- Default
end

local function TeleportTo(cf)
    pcall(function()
        HumanoidRootPart.CFrame = cf * CFrame.new(0, 5, 0)
    end)
end

local function AttackEnemy(enemy)
    pcall(function()
        if enemy and enemy:FindFirstChild("HumanoidRootPart") and enemy.Humanoid.Health > 0 then
            TeleportTo(enemy.HumanoidRootPart.CFrame * CFrame.new(0,10,0))
            VirtualInputManager:SendMouseButtonEvent(0,0,0,true,game,1); wait(0.1); VirtualInputManager:SendMouseButtonEvent(0,0,0,false,game,1)
        end
    end)
end

local function GetClosestEnemy(name)
    local closest, dist = nil, math.huge
    for _, e in pairs(Workspace.Enemies:GetChildren()) do
        if e.Name == name and e:FindFirstChild("Humanoid") and e.Humanoid.Health > 0 then
            local d = (HumanoidRootPart.Position - e.HumanoidRootPart.Position).Magnitude
            if d < dist then closest = e; dist = d end
        end
    end
    return closest
end

