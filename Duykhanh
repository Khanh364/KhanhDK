getgenv().Config = {
    ["FastAttack"] = true,
    ["ClickAttack"] = true
}

coroutine.wrap(function()
    local StopCamera = require(game.ReplicatedStorage.Util.CameraShaker)
    StopCamera:Stop()
    for _, v in pairs(getreg()) do
        if typeof(v) == "function" and getfenv(v).script == game:GetService("Players").LocalPlayer.PlayerScripts.CombatFramework then
            for _, v2 in pairs(debug.getupvalues(v)) do
                if typeof(v2) == "table" then
                    spawn(function()
                        game:GetService("RunService").RenderStepped:Connect(function()
                            if getgenv().Config.FastAttack then
                                pcall(function()
                                    v2.activeController.timeToNextAttack = -(math.huge^math.huge^math.huge)
                                    v2.activeController.attacking = false
                                    v2.activeController.increment = 4
                                    v2.activeController.blocking = false
                                    v2.activeController.hitboxMagnitude = 150
                                    v2.activeController.humanoid.AutoRotate = true
                                    v2.activeController.focusStart = 0
                                    v2.activeController.currentAttackTrack = 0
                                    sethiddenproperty(game:GetService("Players").LocalPlayer, "SimulationRadius", math.huge)
                                end)
                            end
                        end)
                    end)
                end
            end
        end
    end
end)()

spawn(function()
    game:GetService("RunService").RenderStepped:Connect(function()
        if getgenv().Config.ClickAttack then
            pcall(function()
                game:GetService'VirtualUser':CaptureController()
                game:GetService'VirtualUser':Button1Down(Vector2.new(0,1,0,1))
            end)
        end
    end)
end)
