local TweenService = game:GetService("TweenService")
local tweenInfo = TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

Frame.MouseEnter:Connect(function()
    TweenService:Create(Frame, tweenInfo, {Size = UDim2.new(0, 92, 0, 92)}):Play()
    TweenService:Create(UIStroke, tweenInfo, {Thickness = 8, Transparency = 0}):Play()
    TweenService:Create(UIGradient, TweenInfo.new(2, Enum.EasingStyle.Linear), {Rotation = 405}):Play()
end)

Frame.MouseLeave:Connect(function()
    TweenService:Create(Frame, tweenInfo, {Size = UDim2.new(0, 80, 0, 80)}):Play()
    TweenService:Create(UIStroke, tweenInfo, {Thickness = 4, Transparency = 0.3}):Play()
end)

Frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        TweenService:Create(Frame, TweenInfo.new(0.15, Enum.EasingStyle.Quad), {Size = UDim2.new(0, 74, 0, 74)}):Play()
    end
end)

Frame.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        TweenService:Create(Frame, TweenInfo.new(0.25, Enum.EasingStyle.Back), {Size = UDim2.new(0, 92, 0, 92)}):Play()
    end
end)

Frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        -- Hiệu ứng âm thanh khi click
        local Sound = Instance.new("Sound")
        Sound.SoundId = "rbxassetid://9119707214"  -- âm thanh click neon / sci-fi (miễn phí Roblox)
        Sound.Volume = 0.6
        Sound.PlayOnRemove = false
        Sound.Parent = Frame
        Sound:Play()
        task.delay(2, function() Sound:Destroy() end)

        for i = 1, 18 do
            local particle = Instance.new("ImageLabel")
            particle.Size = UDim2.new(0, math.random(18, 36), 0, math.random(18, 36))
            particle.Position = UDim2.new(0.5, 0, 0.5, 0)
            particle.AnchorPoint = Vector2.new(0.5, 0.5)
            particle.BackgroundTransparency = 1
            particle.Image = "rbxassetid://6031094667"
            particle.ImageColor3 = Color3.fromHSV(math.random(), 0.8, 1)
            particle.ImageTransparency = 0.2
            particle.Parent = Frame

            local angle = math.rad(math.random(0, 360))
            local dist = math.random(90, 180)
            local target = UDim2.new(0.5, math.cos(angle) * dist, 0.5, math.sin(angle) * dist)

            TweenService:Create(particle, TweenInfo.new(0.8 + math.random()/2, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
                Position = target,
                Size = UDim2.new(0, 0, 0, 0),
                ImageTransparency = 1,
                Rotation = math.random(-720, 720)
            }):Play()

            task.delay(1.3, function() particle:Destroy() end)
        end

        local vim = game:GetService("VirtualInputManager")
        vim:SendKeyEvent(true, Enum.KeyCode.RightControl, false, game)
        task.wait(0.03)
        vim:SendKeyEvent(false, Enum.KeyCode.RightControl, false, game)
    end
end)

spawn(function()
