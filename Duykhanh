local flyConn, bg
FruitSection:NewToggle("Fly (Toggle)", "", function(s)
    getgenv().Config.FlyEnabled = s
    if s then
        bg = Instance.new("BodyVelocity")
        bg.MaxForce = Vector3.new(4000,4000,4000)
        bg.Velocity = Vector3.new()
        bg.Parent = HumanoidRootPart
        flyConn = RunService.Heartbeat:Connect(function()
            if getgenv().Config.FlyEnabled then
                local cam = Workspace.CurrentCamera
                bg.Velocity = (cam.CFrame.LookVector * Vector3.new(1,0,1)).Unit * getgenv().Config.FlySpeed + Vector3.new(0, UserInputService:IsKeyDown(Enum.KeyCode.Space) and 50 or UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) and -50 or 0, 0)
            else
                flyConn:Disconnect()
                if bg then bg:Destroy() end
            end
        end)
    else
        if flyConn then flyConn:Disconnect() end
        if bg then bg:Destroy() end
    end
end)

