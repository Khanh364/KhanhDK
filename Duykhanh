Tabs.Main:AddToggle("FastAttack", {Title = "Fast Attack Aura", Default = false}):OnChanged(function(V) fastAttack = V end)
Tabs.Main:AddToggle("AutoHaki", {Title = "Auto Haki (Buso/Ken)", Default = false}):OnChanged(function(V) autoHaki = V end)

