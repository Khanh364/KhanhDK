local TweenService = game:GetService("TweenService")
local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

-- Hover animation
TextButton.MouseEnter:Connect(function()
    TweenService:Create(TextButton, tweenInfo, {Size = UDim2.new(0, 80, 0, 80), BackgroundTransparency = 0.2}):Play()
    TweenService:Create(UIStroke, tweenInfo, {Thickness = 6, Transparency = 0}):Play()
    TweenService:Create(UIGradient, TweenInfo.new(1.5, Enum.EasingStyle.Linear), {Rotation = 360}):Play() -- gradient quay
end)

TextButton.MouseLeave:Connect(function()
    TweenService:Create(TextButton, tweenInfo, {Size = UDim2.new(0, 70, 0, 70), BackgroundTransparency = 0.4}):Play()
    TweenService:Create(UIStroke, tweenInfo, {Thickness = 3, Transparency = 0.2}):Play()
end)

TextButton.MouseButton1Down:Connect(function()
    TweenService:Create(TextButton, TweenInfo.new(0.15), {Size = UDim2.new(0, 65, 0, 65)}):Play()
end)

TextButton.MouseButton1Up:Connect(function()
    TweenService:Create(TextButton, TweenInfo.new(0.2), {Size = UDim2.new(0, 80, 0, 80)}):Play()
end)

-- Particle sparkle wow khi click (nhiều hạt bay ra)
TextButton.MouseButton1Click:Connect(function()
    for i = 1, 12 do  -- 12 hạt sparkle
        local sparkle = Instance.new("ImageLabel")
        sparkle.Size = UDim2.new(0, math.random(20, 40), 0, math.random(20, 40))
        sparkle.Position = UDim2.new(0.5, 0, 0.5, 0)
        sparkle.AnchorPoint = Vector2.new(0.5, 0.5)
        sparkle.BackgroundTransparency = 1
        sparkle.Image = "rbxassetid://6031094667"  -- sparkle texture
        sparkle.ImageColor3 = Color3.fromRGB(0, 255, math.random(150, 255))
        sparkle.ImageTransparency = 0
        sparkle.Parent = TextButton

        local randomAngle = math.rad(math.random(0, 360))
        local distance = math.random(80, 150)
        local targetPos = UDim2.new(0.5, math.cos(randomAngle) * distance, 0.5, math.sin(randomAngle) * distance)

        TweenService:Create(sparkle, TweenInfo.new(math.random(6,10)/10, Enum.EasingStyle.Sine, Enum.EasingDirection.Out), {
            Position = targetPos,
            Size = UDim2.new(0, 0, 0, 0),
            ImageTransparency = 1,
            Rotation = math.random(-360, 360)
        }):Play()

        task.delay(1, function() sparkle:Destroy() end)
    end

    local vim = game:GetService("VirtualInputManager")
    vim:SendKeyEvent(true, Enum.KeyCode.RightControl, false, game)
    task.wait(0.03)
    vim:SendKeyEvent(false, Enum.KeyCode.RightControl, false, game)
end)

-- Shine loop nhẹ (gradient di chuyển liên tục)
spawn(function()
    while true do
        UIGradient.Offset = Vector2.new(-1, 0)
        TweenService:Create(UIGradient, TweenInfo.new(3, Enum.EasingStyle.Linear), {Offset = Vector2.new(1, 0)}):Play()
        task.wait(3)
    end
end)

