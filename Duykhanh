local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Khanh Hub | PVP EDITION",
   Icon = "sword",
   LoadingTitle = "Skill Aim Fixed",
   LoadingSubtitle = "by DK",
   ConfigurationSaving = { Enabled = true, FolderName = "KhanhPVP", FileName = "Main" },
   KeySystem = false
})

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local aimbotEnabled, aimPart, aimFOV, aimSmooth = false, "HumanoidRootPart", 150, 5
local skillAimEnabled = false
local killAuraEnabled, killAuraRange = false, 20
local hitboxEnabled, hitboxSize = false, 15
local autoV3, autoV4 = false, false

local function getClosestPlayer()
   local target, dist = nil, aimFOV
   for _, p in ipairs(Players:GetPlayers()) do
      if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild(aimPart) then
         local pos, onScreen = Camera:WorldToViewportPoint(p.Character[aimPart].Position)
         if onScreen then
            local magnitude = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
            if magnitude < dist then dist, target = magnitude, p end
         end
      end
   end
   return target
end

local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local args = {...}
    local method = getnamecallmethod()
    
    if skillAimEnabled and (method == "FireServer" or method == "InvokeServer") then
        local target = getClosestPlayer()
        if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
            local targetPos = target.Character.HumanoidRootPart.Position
            for i, arg in pairs(args) do
                if typeof(arg) == "Vector3" then
                    args[i] = targetPos
                elseif typeof(arg) == "CFrame" then
                    args[i] = CFrame.new(targetPos)
                end
            end
        end
    end
    return oldNamecall(self, unpack(args))
end)

