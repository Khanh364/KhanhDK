local player = game:GetService("Players").LocalPlayer
local runService = game:GetService("RunService")
local workspace = game:GetService("Workspace")
local lighting = game:GetService("Lighting")
local terrain = workspace.Terrain
local camera = workspace.CurrentCamera
local virtualUser = game:GetService("VirtualUser")
local getgenv = getgenv or function() return _G end

getgenv().FastAttack = true
getgenv().AutoClick = true
getgenv().AntiSitEnabled = true
getgenv().Noclip = true

getgenv().AutoAimbot = true 
getgenv().TargetRadius = 150 
getgenv().Prediction = 0.165 
getgenv().Smoothness = 0.5 

getgenv().HitboxEnabled = true
getgenv().HitboxSize = 35 
getgenv().HitboxTransparency = 0.6 

getgenv().RemoveAttackEffects = true -- Tắt hiệu ứng đánh

local function OptimizePerformance()
    lighting.GlobalShadows = false
    lighting.FogEnd = 9e9
    lighting.Brightness = 0

    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") then
            v.Material = Enum.Material.SmoothPlastic
            v.Reflectance = 0
        elseif v:IsA("Decal") or v:IsA("Texture") or v:IsA("ParticleEmitter") or v:IsA("Trail") then
            v:Destroy()
        end
    end

    if terrain then
        terrain.WaterWaveSize = 0
        terrain.WaterWaveSpeed = 0
        terrain.WaterReflectance = 0
        terrain.WaterTransparency = 0
    end
end
OptimizePerformance()

-- Xóa hiệu ứng liên tục khi chúng xuất hiện
local function RemoveVFX(child)
    if not getgenv().RemoveAttackEffects then return end
    task.wait()
    if child:IsA("ParticleEmitter") or child:IsA("Trail") or child:IsA("Beam") or child:IsA("Explosion") or child:IsA("Fire") or child:IsA("Smoke") or child:IsA("Sparkles") then
        pcall(function() child:Destroy() end)
    elseif child:IsA("BasePart") and (child.Name:lower():match("effect") or child.Name:lower():match("slash") or child.Name:lower():match("magic")) then
        pcall(function() child:Destroy() end)
    end
end

workspace.DescendantAdded:Connect(RemoveVFX)

local function AntiSit(character)
    local humanoid = character:WaitForChild("Humanoid", 5)
    if humanoid then
        if getgenv().AntiSitEnabled then
            humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, false)
        end
    end
end

local function AntiStun(character)
    character.ChildAdded:Connect(function(child)
        local name = child.Name:lower()
        if name:match("stun") or name:match("frozen") or name:match("ice") then
            task.wait()
            child:Destroy()
        end
    end)
    character.DescendantAdded:Connect(RemoveVFX)
end

player.CharacterAdded:Connect(function(character)
    AntiSit(character)
    AntiStun(character)
end)

if player.Character then
    AntiSit(player.Character)
    AntiStun(player.Character)
end

local function ExecuteCombat()
    if not player.Character then return end
    
    local tool = player.Character:FindFirstChildOfClass("Tool")
    if tool then
        if getgenv().AutoClick then
            virtualUser:CaptureController()
            virtualUser:ClickButton1(Vector2.new(0,0))
            tool:Activate()
        end
        
        if getgenv().FastAttack then
            local cooldown = tool:FindFirstChild("Cooldown") or tool:FindFirstChild("CD")
            if cooldown and cooldown:IsA("NumberValue") then
                cooldown.Value = 0
            end
            
            local remote = tool:FindFirstChild("RemoteEvent") or tool:FindFirstChild("AttackRemote")
            if remote and remote:IsA("RemoteEvent") then
                remote:FireServer()
            end
        end
    end
end

runService.RenderStepped:Connect(ExecuteCombat)

runService.Stepped:Connect(function()
    if getgenv().Noclip and player.Character then
        for _, part in pairs(player.Character:GetDescendants()) do
            if part:IsA("BasePart") and part.CanCollide then
                part.CanCollide = false
            end
        end
    end
end)

local currentTarget = nil

local function GetClosestPlayerToCharacter()
    local closestPlayer = nil
    local shortestDistance = math.huge
    local localChar = player.Character
    local localHRP = localChar and localChar:FindFirstChild("HumanoidRootPart")

    if not localHRP then return nil end

    for _, v in pairs(game:GetService("Players"):GetPlayers()) do
        if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local humanoid = v.Character:FindFirstChild("Humanoid")
            if humanoid and humanoid.Health > 0 then
                local distance = (v.Character.HumanoidRootPart.Position - localHRP.Position).Magnitude
                if distance < shortestDistance and distance <= getgenv().TargetRadius then
                    closestPlayer = v
                    shortestDistance = distance
                end
            end
        end
    end
    return closestPlayer
end

runService.RenderStepped:Connect(function()
    if not getgenv().AutoAimbot then return end
    
    if not currentTarget or not currentTarget.Character or not currentTarget.Character:FindFirstChild("Humanoid") or currentTarget.Character.Humanoid.Health <= 0 then
        currentTarget = GetClosestPlayerToCharacter()
    end
    
    if currentTarget and currentTarget.Character and currentTarget.Character:FindFirstChild("HumanoidRootPart") then
        local localChar = player.Character
        local localHRP = localChar and localChar:FindFirstChild("HumanoidRootPart")
        local targetHRP = currentTarget.Character.HumanoidRootPart
        
        if localHRP and (targetHRP.Position - localHRP.Position).Magnitude > getgenv().TargetRadius then
            currentTarget = nil
            return
        end

        local predictedPos = targetHRP.Position + (targetHRP.Velocity * getgenv().Prediction)
        local targetCFrame = CFrame.new(camera.CFrame.Position, predictedPos)
        camera.CFrame = camera.CFrame:Lerp(targetCFrame, getgenv().Smoothness)
    end
end)

runService.RenderStepped:Connect(function()
    if not getgenv().HitboxEnabled then return end
    
    for _, v in pairs(game:GetService("Players"):GetPlayers()) do
        if v ~= player and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = v.Character.HumanoidRootPart
            local humanoid = v.Character:FindFirstChild("Humanoid")
            
            if humanoid and humanoid.Health > 0 then
                hrp.Size = Vector3.new(getgenv().HitboxSize, getgenv().HitboxSize, getgenv().HitboxSize)
                hrp.Transparency = getgenv().HitboxTransparency
                hrp.BrickColor = BrickColor.new("Really red")
                hrp.Material = Enum.Material.Neon
                hrp.CanCollide = false
            else
                hrp.Size = Vector3.new(2, 2, 1)
                hrp.Transparency = 1
            end
        end
    end
end)

