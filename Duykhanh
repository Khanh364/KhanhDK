local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Khanh Hub | PVP EDITION",
   Icon = "sword",
   LoadingTitle = "PVP Script Loading...",
   LoadingSubtitle = "by DK",
   ConfigurationSaving = { Enabled = true, FolderName = "KhanhPVP", FileName = "Main" },
   KeySystem = false
})

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local aimbotEnabled, aimbotPart, aimbotFOV, aimbotSmooth = false, "Head", 150, 5
local killAuraEnabled, killAuraRange = false, 20
local hitboxEnabled, hitboxSize = false, 15
local autoParry, antiStun = false, false
local walkSpeed, jumpPower = 16, 50

local function getCharacter() return LocalPlayer.Character end
local function getHRP(char) return (char or getCharacter()):FindFirstChild("HumanoidRootPart") end

local function getClosestPlayer()
   local target, dist = nil, aimbotFOV
   for _, p in ipairs(Players:GetPlayers()) do
      if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild(aimbotPart) then
         local pos, onScreen = Camera:WorldToViewportPoint(p.Character[aimbotPart].Position)
         if onScreen then
            local magnitude = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
            if magnitude < dist then dist, target = magnitude, p end
         end
      end
   end
   return target
end

