-- Khanh's Blox Fruits Hub V4 - Fruit Tab Giống Banana Hub

local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = Library.CreateLib("Khanh's Blox Fruits Hub V4", "DarkTheme")

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Workspace = game:GetService("Workspace")
local RunService = game:GetService("RunService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local UserInputService = game:GetService("UserInputService")
local StarterGui = game:GetService("StarterGui")

local Player = Players.LocalPlayer
local Character = Player.Character or Player.CharacterAdded:Wait()
local HumanoidRootPart = Character:WaitForChild("HumanoidRootPart")
local Remotes = ReplicatedStorage:WaitForChild("Remotes")
local CommF_ = Remotes:WaitForChild("CommF_")

getgenv().Config = {
    FruitSniper = false,
    FruitESP = false,
    FruitNotifier = false,
    AutoStore = true,
    BringFruit = false,
    FruitFilter = "Mythical",
    FlyEnabled = false,
    FlySpeed = 100,
    WalkSpeed = 16,
    JumpPower = 50,
    NoClip = false
}

local FruitRarity = {
    Common = {"Bomb", "Spike", "Chop", "Smoke", "Spring"},
    Uncommon = {"Flame", "Ice", "Sand", "Light", "Dark"},
    Rare = {"Rubber", "Barrier", "Magma", "Falcon"},
    Legendary = {"Venom", "Control", "Spirit", "Sound", "Blade"},
    Mythical = {"Dragon", "Leopard", "Mammoth", "T-Rex", "Kitsune", "Dough"}
}

local function GetRarity(fruitName)
    fruitName = fruitName:gsub(" ", ""):lower()
    for rarity, fruits in pairs(FruitRarity) do
        for _, f in pairs(fruits) do
            if fruitName:find(f:lower()) then return rarity end
        end
    end
    return "Common"
end

local function IsGoodFruit(fruitName)
    local rarity = GetRarity(fruitName)
    return getgenv().Config.FruitFilter == "All" or rarity == getgenv().Config.FruitFilter
end

local function Teleport(cf)
    pcall(function() HumanoidRootPart.CFrame = cf * CFrame.new(0,5,0) end)
end

local function PickupFruit(fruit)
    if fruit and fruit:FindFirstChild("Handle") and fruit.Handle:FindFirstChild("ClickDetector") then
        Teleport(fruit.Handle.CFrame)
        fireclickdetector(fruit.Handle.ClickDetector)
        if getgenv().Config.AutoStore and CommF_ then
            CommF_:InvokeServer("StoreFruit", fruit.Name, "true")
        end
    end
end

spawn(function()
    while wait(0.5) do
        if getgenv().Config.FruitSniper then
            for _, obj in pairs(Workspace:GetChildren()) do
                if obj:IsA("Tool") and obj.Name:find("Fruit") and IsGoodFruit(obj.Name) then
                    PickupFruit(obj)
                    break
                end
            end
        end
    end
end)

local FruitHighlights = {}
spawn(function()
    while wait() do
        if getgenv().Config.FruitESP then
            for _, obj in pairs(Workspace:GetChildren()) do
                if obj:IsA("Tool") and obj.Name:find("Fruit") and not FruitHighlights[obj] then
                    local highlight = Instance.new("Highlight", obj)
                    highlight.FillColor = Color3.fromRGB(255, 255, 0)
                    highlight.OutlineColor = Color3.fromRGB(255, 0, 0)
                    FruitHighlights[obj] = highlight
                end
            end
        else
            for obj, h in pairs(FruitHighlights) do
                if h then h:Destroy() end
            end
            FruitHighlights = {}
        end
    end
end)

spawn(function()
    while wait(1) do
        if getgenv().Config.FruitNotifier then
            for _, obj in pairs(Workspace:GetChildren()) do
                if obj:IsA("Tool") and obj.Name:find("Fruit") then
                    local rarity = GetRarity(obj.Name)
                    if rarity == "Legendary" or rarity == "Mythical" then
                        StarterGui:SetCore("SendNotification", {
                            Title = "Rare Fruit Detected",
                            Text = obj.Name .. " (" .. rarity .. ")",
                            Duration = 5
                        })
                        local sound = Instance.new("Sound", Workspace)
                        sound.SoundId = "rbxassetid://131961136"
                        sound:Play()
                        sound.Ended:Connect(function() sound:Destroy() end)
                    end
                end
            end
        end
    end
end)

spawn(function()
    while wait(2) do
        if getgenv().Config.BringFruit then
            for _, obj in pairs(Workspace:GetChildren()) do
                if obj:IsA("Tool") and obj.Name:find("Fruit") then
                    if obj:FindFirstChild("Handle") then
                        obj.Handle.CFrame = HumanoidRootPart.CFrame * CFrame.new(0,0,-5)
                    end
                end
            end
        end
    end
end)

local FruitTab = Window:NewTab("🍌 Fruit")
local FruitSec = FruitTab:NewSection("Fruit Features")

FruitSec:NewToggle("Fruit Sniper", "", function(s)
    getgenv().Config.FruitSniper = s
end)

FruitSec:NewDropdown("Filter Rarity", "", {"All", "Common", "Uncommon", "Rare", "Legendary", "Mythical"}, function(s)
    getgenv().Config.FruitFilter = s
end)

FruitSec:NewToggle("Fruit ESP", "", function(s)
    getgenv().Config.FruitESP = s
end)

FruitSec:NewToggle("Notifier Legendary/Mythical", "", function(s)
    getgenv().Config.FruitNotifier = s
end)

FruitSec:NewToggle("Bring All Fruits", "", function(s)
    getgenv().Config.BringFruit = s
end)

FruitSec:NewToggle("Auto Store", "", function(s)
    getgenv().Config.AutoStore = s
end)

FruitSec:NewButton("TP Nearest Fruit", "", function()
    local nearest, dist = nil, math.huge
    for _, obj in pairs(Workspace:GetChildren()) do
        if obj:IsA("Tool") and obj.Name:find("Fruit") then
            local d = (HumanoidRootPart.Position - obj.Handle.Position).Magnitude
            if d < dist then nearest = obj.Handle.CFrame; dist = d end
        end
    end
    if nearest then Teleport(nearest) end
end)

local MiscTab = Window:NewTab("Misc")
local MiscSec = MiscTab:NewSection("Movement")

MiscSec:NewToggle("Fly", "", function(s)
    getgenv().Config.FlyEnabled = s
    local bg = Instance.new("BodyVelocity", HumanoidRootPart)
    bg.MaxForce = Vector3.new(1e9,1e9,1e9)
    bg.Velocity = Vector3.new()
    local conn = RunService.Heartbeat:Connect(function()
        if not getgenv().Config.FlyEnabled then
            bg:Destroy()
            conn:Disconnect()
            return
        end
        local cam = Workspace.CurrentCamera.CFrame
        bg.Velocity = cam.LookVector * getgenv().Config.FlySpeed
    end)
end)

MiscSec:NewSlider("Fly Speed", "", 500, 50, function(v) getgenv().Config.FlySpeed = v end)

MiscSec:NewToggle("NoClip", "", function(s) getgenv().Config.NoClip = s end)

spawn(function()
    while wait() do
        if getgenv().Config.NoClip and Character then
            for _, p in pairs(Character:GetDescendants()) do
                if p:IsA("BasePart") then p.CanCollide = false end
            end
        end
    end
end)

MiscSec:NewSlider("Walk Speed", "", 500, 16, function(v)
    getgenv().Config.WalkSpeed = v
    pcall(function() Character.Humanoid.WalkSpeed = v end)
end)

MiscSec:NewSlider("Jump Power", "", 500, 50, function(v)
    getgenv().Config.JumpPower = v
    pcall(function() Character.Humanoid.JumpPower = v end)
end)

Player.CharacterAdded:Connect(function(c)
    Character = c
    HumanoidRootPart = c:WaitForChild("HumanoidRootPart")
end)

Library:ToggleUI()
