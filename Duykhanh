local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Khanh Hub - PvP God Mode",
   Icon = "award",
   LoadingTitle = "Skibidi DK",
   LoadingSubtitle = "Phiên bản Mobile Pro",
   Theme = "Pear",
   ConfigurationSaving = { Enabled = true, FolderName = "KhanhHub", FileName = "PvPConfig" }
})

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local silentAimEnabled = false
local killAuraEnabled = false
local noclipEnabled = false
local infJumpEnabled = false
local noSlowdownEnabled = false
local originalWalkSpeed = 16
local originalJumpPower = 50
local silentAimFOV = 150
local aimPart = "HumanoidRootPart"

local function getCharacter() return LocalPlayer.Character end
local function getHumanoid() return getCharacter() and getCharacter():FindFirstChildWhichIsA("Humanoid") end
local function getHRP() return getCharacter() and getCharacter():FindFirstChild("HumanoidRootPart") end

local Tab1 = Window:CreateTab("Silent Aim", "crosshair")
Tab1:CreateToggle({
   Name = "Silent Aim (Ngắm ngầm)",
   CurrentValue = false,
   Callback = function(Value) silentAimEnabled = Value end,
})

Tab1:CreateSlider({
   Name = "Tầm ngắm (FOV)",
   Range = {50, 800},
   Increment = 10,
   CurrentValue = 150,
   Callback = function(Value) silentAimFOV = Value end,
})

local Tab2 = Window:CreateTab("Combat", "sword")
Tab2:CreateToggle({
   Name = "Kill Aura (Tự đánh)",
   CurrentValue = false,
   Callback = function(Value) killAuraEnabled = Value end,
})

Tab2:CreateToggle({
   Name = "No Slowdown (Không bị chậm khi đánh)",
   CurrentValue = false,
   Callback = function(Value) noSlowdownEnabled = Value end,
})

local Tab3 = Window:CreateTab("Movement", "zap")
Tab3:CreateSlider({
   Name = "Tốc độ chạy",
   Range = {16, 500},
   Increment = 2,
   CurrentValue = 16,
   Callback = function(Value) originalWalkSpeed = Value end,
})

Tab3:CreateSlider({
   Name = "Độ cao nhảy",
   Range = {50, 1000},
   Increment = 10,
   CurrentValue = 50,
   Callback = function(Value) originalJumpPower = Value end,
})

Tab3:CreateToggle({
   Name = "Nhảy vô hạn (Inf Jump)",
   CurrentValue = false,
   Callback = function(Value) infJumpEnabled = Value end,
})

Tab3:CreateToggle({
   Name = "Xuyên tường (Noclip)",
   CurrentValue = false,
   Callback = function(Value) noclipEnabled = Value end,
})

UserInputService.JumpRequest:Connect(function()
   if infJumpEnabled then
      local hum = getHumanoid()
      if hum then 
         hum:ChangeState(Enum.HumanoidStateType.Jumping) 
      end
   end
end)

RunService.Heartbeat:Connect(function()
   local char = getCharacter()
   if not char then return end
   local myHRP = getHRP()
   local tool = char:FindFirstChildWhichIsA("Tool")
   
   local target = nil
   local dist_f = silentAimFOV
   for _, p in ipairs(Players:GetPlayers()) do
      if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild(aimPart) then
         local pos, onScreen = Camera:WorldToViewportPoint(p.Character[aimPart].Position)
         if onScreen then
            local d = (Vector2.new(pos.X, pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
            if d < dist_f then 
               dist_f = d 
               target = p.Character 
            end
         end
      end
   end

   if target and tool then
      local tPart = target[aimPart]
      local dist = (tPart.Position - myHRP.Position).Magnitude
      
      if (silentAimEnabled or killAuraEnabled) and dist <= 25 then
         tool:Activate()
         for _, r in ipairs(tool:GetDescendants()) do
            if r:IsA("RemoteEvent") then
               r:FireServer(tPart.Position)
               r:FireServer(target)
            end
         end
      end
   end
end)

RunService.Stepped:Connect(function()
   local char = getCharacter()
   if not char then return end
   
   if noclipEnabled then
      for _, part in ipairs(char:GetDescendants()) do
         if part:IsA("BasePart") then part.CanCollide = false end
      end
   end
   
   local hum = char:FindFirstChildWhichIsA("Humanoid")
   if hum then
      hum.WalkSpeed = originalWalkSpeed
      hum.UseJumpPower = true
      hum.JumpPower = originalJumpPower
      
      if noSlowdownEnabled then
         if hum.PlatformStand then hum.PlatformStand = false end
      end
   end
end)

Rayfield:Notify({
   Title = "Khanh Hub",
   Content = "Script Loaded!",
   Duration = 5,
   Image = "award"
})
