local lp = game.Players.LocalPlayer
local RS = game:GetService("ReplicatedStorage")
local WS = game:GetService("Workspace")
local VU = game:GetService("VirtualUser")

getgenv().Config = {
    FastAttack = false,
    AutoFarmLevel = false,
    AutoMastery = false,
    AutoRaid = false,
    AutoFruitSniper = false
    -- Thêm các config khác nếu cần, nhưng để test cơ bản trước
}

-- Fast Attack
local mt = getrawmetatable(game)
local old = mt.__namecall
setreadonly(mt, false)
mt.__namecall = newcclosure(function(self, ...)
    if Config.FastAttack and getnamecallmethod() == "FireServer" and self.Name == "MeleeDamage" then
        for i = 1, 5 do old(self, ...) end
    end
    return old(self, ...)
end)
setreadonly(mt, true)

Tabs.Main:AddToggle("FA", {
    Title = "Fast Attack",
    Default = false,
    Callback = function(v) Config.FastAttack = v end
})

-- Auto Farm Level (test cơ bản)
Tabs.Farm:AddToggle("AFL", {
    Title = "Auto Farm Level",
    Default = false,
    Callback = function(v)
        Config.AutoFarmLevel = v
        spawn(function()
            while Config.AutoFarmLevel do
                pcall(function()
                    local mob = WS.Enemies:FindFirstChildWhichIsA("Model")
                    if mob then
                        lp.Character.HumanoidRootPart.CFrame = mob.HumanoidRootPart.CFrame * CFrame.new(0,10,0)
                        VU:ClickButton1(Vector2.new())
                    end
                end)
                task.wait(0.3)
            end
        end)
    end
})

-- Nút toggle GUI (Pro button)
local sg = Instance.new("ScreenGui")
sg.Parent = game.CoreGui
sg.ResetOnSpawn = false

local btn = Instance.new("TextButton", sg)
btn.Size = UDim2.new(0,60,0,60)
btn.Position = UDim2.new(0,10,0.5,0)
btn.BackgroundColor3 = Color3.fromRGB(0,0,0)
btn.BackgroundTransparency = 0.3
btn.Text = "Pro"
btn.TextColor3 = Color3.fromRGB(0,255,0)
btn.TextSize = 20
btn.Font = Enum.Font.SourceSansBold
btn.Draggable = true

local corner = Instance.new("UICorner", btn)
corner.CornerRadius = UDim.new(0,12)

btn.MouseButton1Click:Connect(function()
    local vim = game:GetService("VirtualInputManager")
    vim:SendKeyEvent(true, Enum.KeyCode.RightControl, false, game)
    task.wait(0.03)
    vim:SendKeyEvent(false, Enum.KeyCode.RightControl, false, game)
end)

