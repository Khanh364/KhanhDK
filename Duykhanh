getgenv().Config = {
    FastAttack = true,
    AttackRepeat = 10,
    NoAnimation = true,
    NoCooldown = true,
    HitboxSize = 50,
    HitboxTransparency = 0.8,
    PlayerESP = true,
    Noclip = true,
    AntiSit = true,
    WalkOnWater = true,
    RemoveEffects = true,
    AutoFace = true,
    TargetDistance = 1000,
    Fly = true,
    FlySpeed = 350,
    Camlock = true,
    DeleteMap = true,
    AntiAdmin = true,
    ServerHopOnAdmin = true,
    LowPlayerServer = true,
    SafeMagnitude = 45,
    RandomizeDelay = true,
    HideVelocity = true,
    Prediction = true,
    PredictionIntensity = 0.15,
    TeleportToTarget = false,
    TpOffset = Vector3.new(0, 5, 2),
    AutoHopWhenNoTargets = true,
    InfEnergy = true
}

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")
local workspace = game:GetService("Workspace")
local lighting = game:GetService("Lighting")
local TeleportService = game:GetService("TeleportService")
local HttpService = game:GetService("HttpService")
local Camera = workspace.CurrentCamera

local CombatFramework
pcall(function()
    CombatFramework = require(LocalPlayer.PlayerScripts.CombatFramework)
end)

local function IsEssential(obj)
    if Players:GetPlayerFromCharacter(obj) or obj == LocalPlayer.Character then return true end
    if obj:IsA("Model") and obj:FindFirstChildOfClass("Humanoid") then return true end
    if obj.Name == "WaterPlatform" or obj:IsA("Camera") or obj:IsA("Terrain") then return true end
    return false
end

local function LowGFX(v)
    if v:IsA("BasePart") then
        v.Material = Enum.Material.SmoothPlastic
        v.Reflectance = 0
        v.CastShadow = false
    elseif v:IsA("Decal") or v:IsA("Texture") then
        if v.Name ~= "Face" then v:Destroy() end
    elseif v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Beam") or v:IsA("Fire") or v:IsA("Smoke") or v:IsA("Sparkles") then
        v.Enabled = false
        task.delay(0, function() v:Destroy() end)
    elseif v:IsA("Explosion") or v:IsA("PointLight") or v:IsA("SpotLight") or v:IsA("SurfaceLight") then
        v:Destroy()
    end
end

local function ClearMap()
    if not getgenv().Config.DeleteMap then return end
    for _, obj in pairs(workspace:GetChildren()) do
        if not IsEssential(obj) then pcall(function() obj:Destroy() end) end
    end
end

local function InitialOptimize()
    settings().Rendering.QualityLevel = 1
    lighting.GlobalShadows = false
    lighting.FogEnd = 9e9
    lighting.Brightness = 1
    for _, v in pairs(lighting:GetChildren()) do
        if v:IsA("PostProcessEffect") or v:IsA("BlurEffect") or v:IsA("SunRaysEffect") or v:IsA("BloomEffect") or v:IsA("DepthOfFieldEffect") then
            v.Enabled = false
        end
    end
    ClearMap()
    for _, v in pairs(workspace:GetDescendants()) do LowGFX(v) end
end

local function ServerHop()
    local PlaceID = game.PlaceId
    local JobID = game.JobId
    local API = "https://games.roblox.com/v1/games/" .. PlaceID .. "/servers/Public?sortOrder=Asc&limit=100"
    local function GetServers(cursor)
        local url = API .. (cursor and "&cursor=" .. cursor or "")
        local success, result = pcall(function()
            return HttpService:JSONDecode(game:HttpGet(url))
        end)
        return success and result or nil
    end
    task.spawn(function()
        local cursor = nil
        while true do
            local servers = GetServers(cursor)
            if not servers then break end
            for _, server in pairs(servers.data) do
                if server.id ~= JobID and server.playing < server.maxPlayers then
                    if getgenv().Config.LowPlayerServer and server.playing > 8 then continue end
                    pcall(function() TeleportService:TeleportToPlaceInstance(PlaceID, server.id, LocalPlayer) end)
                    task.wait(1)
                end
            end
            cursor = servers.nextPageCursor
            if not cursor then break end
            task.wait(0.1)
        end
    end)
end

local function CheckAdmin(player)
    if not getgenv().Config.AntiAdmin then return end
    local isStaff = false
    pcall(function()
        if player:GetRankInGroup(game.CreatorId) >= 200 or player:GetRankInGroup(4442245) >= 200 then
            isStaff = true
        end
    end)
    local adminNames = {"admin", "mod", "staff", "owner", "tester"}
    for _, name in pairs(adminNames) do
        if string.find(player.Name:lower(), name) then isStaff = true end
    end
    if isStaff then
        if getgenv().Config.ServerHopOnAdmin then ServerHop() else LocalPlayer:Kick("Admin Detected") end
    end
end

local function GetNearestTarget()
    local target, nearestDist = nil, getgenv().Config.TargetDistance
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local hum = v.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                local dist = (v.Character.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                if dist < nearestDist then nearestDist = dist; target = v.Character.HumanoidRootPart end
            end
        end
    end
    if not target then
        for _, v in pairs(workspace:GetChildren()) do
            if v:IsA("Model") and v:FindFirstChild("HumanoidRootPart") and v:FindFirstChildOfClass("Humanoid") then
                if v.Humanoid.Health > 0 then
                    local dist = (v.HumanoidRootPart.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                    if dist < nearestDist then nearestDist = dist; target = v.HumanoidRootPart end
                end
            end
        end
    end
    return target
end

local function ExecuteAttack()
    local target = GetNearestTarget()
    if not target then return end
    local dist = (target.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
    if dist > getgenv().Config.SafeMagnitude then return end
    local controller
    pcall(function() controller = CombatFramework.activeController end)
    if controller and controller.equipped then
        local count = 0
        local repeatCount = getgenv().Config.AttackRepeat
        if getgenv().Config.RandomizeDelay then repeatCount = math.random(repeatCount - 3, repeatCount + 2) end
        repeat
            if getgenv().Config.NoCooldown then
                controller.attackInterval = 0 
                controller.timeToNextAttack = 0
                controller.hitboxCreated = false
            end
            pcall(function() controller:attack() end)
            count = count + 1
            if getgenv().Config.RandomizeDelay then task.wait(math.random(1, 5) / 100) end
        until count >= repeatCount
    end
end

local function ApplyESP(plr)
    if not getgenv().Config.PlayerESP then return end
    if plr ~= LocalPlayer and plr.Character and not plr.Character:FindFirstChild("ESPHighlight") then
        local highlight = Instance.new("Highlight", plr.Character)
        highlight.Name = "ESPHighlight"
        highlight.FillColor = Color3.fromRGB(255, 0, 0)
        highlight.FillTransparency = 0.5
        highlight.OutlineTransparency = 1
    end
end

local function SetupCharacter(char)
    local humanoid = char:WaitForChild("Humanoid", 5)
    if not humanoid then return end
    
    if getgenv().Config.AntiSit then
        humanoid:SetStateEnabled(Enum.HumanoidStateType.Seated, false)
    end
    
    humanoid.AnimationPlayed:Connect(function(track)
        if getgenv().Config.NoAnimation then
            local animName = track.Name:lower()
            if animName:find("attack") or animName:find("slash") or animName:find("swing") or animName:find("hit") then
                track:Stop()
            end
        end
    end)
end

workspace.ChildAdded:Connect(function(child)
    task.spawn(function()
        if getgenv().Config.DeleteMap and not IsEssential(child) then
            task.wait(0.1)
            if not IsEssential(child) then child:Destroy() return end
        end
        LowGFX(child)
        for _, v in pairs(child:GetDescendants()) do LowGFX(v) end
    end)
end)

LocalPlayer.CharacterAdded:Connect(SetupCharacter)
if LocalPlayer.Character then SetupCharacter(LocalPlayer.Character) end

local waterPart = Instance.new("Part", workspace)
waterPart.Name = "WaterPlatform"
waterPart.Size = Vector3.new(2000, 2, 2000)
waterPart.Anchored = true
waterPart.Transparency = 1

RunService.RenderStepped:Connect(function()
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
    local myHrp = LocalPlayer.Character.HumanoidRootPart
    waterPart.Position = Vector3.new(myHrp.Position.X, myHrp.Position.Y - 3.5, myHrp.Position.Z)
    waterPart.CanCollide = getgenv().Config.WalkOnWater
    
    local target = GetNearestTarget()
    if target then
        local targetPos = target.Position
        if getgenv().Config.Prediction then
            targetPos = targetPos + (target.Velocity * getgenv().Config.PredictionIntensity)
        end
        if getgenv().Config.Camlock then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, targetPos)
        end
        if getgenv().Config.AutoFace then
            myHrp.CFrame = CFrame.new(myHrp.Position, Vector3.new(targetPos.X, myHrp.Position.Y, targetPos.Z))
        end
        if getgenv().Config.TeleportToTarget then
            myHrp.CFrame = target.CFrame * CFrame.new(getgenv().Config.TpOffset)
        end
    end

    if getgenv().Config.InfEnergy and LocalPlayer.Character:FindFirstChild("Energy") then
        LocalPlayer.Character.Energy.Value = LocalPlayer.Character.Energy.MaxValue
    end

    for _, plr in pairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = plr.Character.HumanoidRootPart
            local hum = plr.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.Health > 0 then
                hrp.Size = Vector3.new(getgenv().Config.HitboxSize, getgenv().Config.HitboxSize, getgenv().Config.HitboxSize)
                hrp.Transparency = getgenv().Config.HitboxTransparency
                hrp.CanCollide = false
                if getgenv().Config.PlayerESP then ApplyESP(plr) end
            else
                hrp.Size = Vector3.new(2, 2, 1)
            end
        end
    end
end)

RunService.Stepped:Connect(function()
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
    local myHrp = LocalPlayer.Character.HumanoidRootPart
    if getgenv().Config.Noclip then
        for _, part in pairs(LocalPlayer.Character:GetDescendants()) do
            if part:IsA("BasePart") then part.CanCollide = false end
        end
    end
    if getgenv().Config.Fly then
        local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
        local moveDir = hum.MoveDirection
        if moveDir.Magnitude > 0 then
            myHrp.CFrame = myHrp.CFrame + (moveDir * (getgenv().Config.FlySpeed / 50))
        end
        myHrp.Velocity = getgenv().Config.HideVelocity and Vector3.new(0, 1.1, 0) or Vector3.zero
    end
end)

Players.PlayerAdded:Connect(CheckAdmin)
for _, plr in pairs(Players:GetPlayers()) do if plr ~= LocalPlayer then CheckAdmin(plr) end end

task.spawn(function()
    InitialOptimize()
    local emptyCount = 0
    while true do
        local target = GetNearestTarget()
        if target then
            emptyCount = 0
            if getgenv().Config.FastAttack then ExecuteAttack() end
        else
            emptyCount = emptyCount + 1
        end
        if getgenv().Config.AutoHopWhenNoTargets and emptyCount >= 50 then
            ServerHop()
            break
        end
        if getgenv().Config.AntiSit and LocalPlayer.Character then
            local hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")
            if hum and hum.Sit then hum.Sit = false end
        end
        task.wait(0.1)
    end
end)
