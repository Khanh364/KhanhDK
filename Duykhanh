local plr = game.Players.LocalPlayer
local rs = game:GetService("ReplicatedStorage")
local remote = rs:FindFirstChild("MainEvent") or rs:FindFirstChild("RemoteEvent")

local config = {
    fastSpeed = 0.03,
    auraRadius = 30,
    auraDamage = 999,
}

coroutine.wrap(function()
    while true do
        pcall(function()
            if remote and plr.Character then
                remote:FireServer("Attack", {Hit = Vector3.new()})
            end
        end)
        task.wait(config.fastSpeed)
    end
end)()

game:GetService("RunService").Heartbeat:Connect(function()
    local char = plr.Character
    if not char then return end
    local root = char:FindFirstChild("HumanoidRootPart")
    if not root then return end
    
    for _, obj in pairs(workspace:GetDescendants()) do
        local hum = obj:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health > 0 and obj ~= char then
            local objRoot = obj:FindFirstChild("HumanoidRootPart")
            if objRoot and (root.Position - objRoot.Position).Magnitude <= config.auraRadius then
                pcall(function()
                    hum:TakeDamage(config.auraDamage)
                end)
            end
        end
    end
end)
