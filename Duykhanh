local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
   Name = "Khanh Hub | Blox Fruits",
   Icon = "award",
   LoadingTitle = "Skibidi Loading...",
   LoadingSubtitle = "by DK",
   ConfigurationSaving = {
      Enabled = true,
      FolderName = "KhanhHubConfig",
      FileName = "Main"
   },
   KeySystem = false
})

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

local aimbotEnabled, killAuraEnabled, espEnabled = false, false, false
local hitboxExpanded, autoFarmEnabled, autoEatEnabled = false, false, false
local aimbotPart, aimbotFOV, aimbotSmooth = "Head", 120, 5
local killAuraRange, hitboxSize, selectedMob = 15, 10, ""

local function getCharacter() return LocalPlayer.Character end
local function getHRP() return getCharacter() and getCharacter():FindFirstChild("HumanoidRootPart") end

local function getClosestPlayer(fov)
   local closestPlayer, closestDist = nil, fov
   local screenCenter = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
   for _, player in ipairs(Players:GetPlayers()) do
      if player ~= LocalPlayer and player.Character and player.Character:FindFirstChild(aimbotPart) then
         local screenPos, onScreen = Camera:WorldToViewportPoint(player.Character[aimbotPart].Position)
         if onScreen then
            local dist = (Vector2.new(screenPos.X, screenPos.Y) - screenCenter).Magnitude
            if dist < closestDist then closestDist, closestPlayer = dist, player end
         end
      end
   end
   return closestPlayer
end

local function getClosestMob(range)
   local closest, closestDist = nil, range
   local myHRP = getHRP()
   if not myHRP then return nil end
   for _, obj in ipairs(workspace.Enemies:GetChildren()) do
      if obj:FindFirstChild("Humanoid") and obj.Humanoid.Health > 0 and obj:FindFirstChild("HumanoidRootPart") then
         if selectedMob == "" or obj.Name:lower():find(selectedMob:lower()) then
            local dist = (obj.HumanoidRootPart.Position - myHRP.Position).Magnitude
            if dist < closestDist then closestDist, closest = dist, obj end
         end
      end
   end
   return closest
end

local TabPVP = Window:CreateTab("PVP", "sword")
TabPVP:CreateToggle({Name = "Aimbot", CurrentValue = false, Callback = function(V) aimbotEnabled = V end})
TabPVP:CreateSlider({Name = "Smoothness", Range = {1, 20}, Increment = 1, CurrentValue = 5, Callback = function(V) aimbotSmooth = V end})
TabPVP:CreateToggle({Name = "Kill Aura", CurrentValue = false, Callback = function(V) killAuraEnabled = V end})
TabPVP:CreateToggle({Name = "Hitbox Expander", CurrentValue = false, Callback = function(V)
   hitboxExpanded = V
   for _, p in ipairs(Players:GetPlayers()) do
      if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
         p.Character.HumanoidRootPart.Size = V and Vector3.new(hitboxSize, hitboxSize, hitboxSize) or Vector3.new(2, 2, 1)
         p.Character.HumanoidRootPart.Transparency = V and 0.7 or 1
      end
   end
end})

local TabFarm = Window:CreateTab("FARM", "wheat")
TabFarm:CreateInput({Name = "Mob Name", PlaceholderText = "Monkey...", Callback = function(V) selectedMob = V end})
TabFarm:CreateToggle({Name = "Auto Farm", CurrentValue = false, Callback = function(V)
   autoFarmEnabled = V
   task.spawn(function()
      while autoFarmEnabled do
         local mob = getClosestMob(1000)
         if mob and getHRP() then getHRP().CFrame = mob.HumanoidRootPart.CFrame * CFrame.new(0, 10, 0) end
         task.wait()
      end
   end)
end})

TabFarm:CreateToggle({Name = "Auto Eat Fruit", CurrentValue = false, Callback = function(V)
   autoEatEnabled = V
   task.spawn(function()
      while autoEatEnabled do
         for _, obj in ipairs(workspace:GetChildren()) do
            if obj:IsA("Tool") and obj.Name:find("Fruit") and getHRP() then
               getHRP().CFrame = obj.Handle.CFrame
               firetouchinterest(getHRP(), obj.Handle, 0)
               task.wait(0.1)
               firetouchinterest(getHRP(), obj.Handle, 1)
            end
         end
         task.wait(1)
      end
   end)
end})

RunService.RenderStepped:Connect(function()
   if aimbotEnabled then
      local target = getClosestPlayer(aimbotFOV)
      if target and target.Character and target.Character:FindFirstChild(aimbotPart) then
         Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, target.Character[aimbotPart].Position), 1/aimbotSmooth)
      end
   end
end)

