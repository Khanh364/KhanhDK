local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()
local SaveManager = loadstring(game:HttpGet("https://raw.githubusercontent.com/dawid-scripts/Fluent/master/Addons/SaveManager.lua"))()

local Window = Fluent:CreateWindow({
    Title = "KhanhUltimate",
    SubTitle = "2026",
    TabWidth = 160,
    Size = UDim2.fromOffset(580, 460),
    Acrylic = true,
    Theme = "Light",
    MinimizeKey = Enum.KeyCode.RightControl
})

local Tabs = {
    Main = Window:AddTab({ Title = "Main", Icon = "home" }),
    Farm = Window:AddTab({ Title = "Farm", Icon = "swords" }),
    Misc = Window:AddTab({ Title = "Misc", Icon = "settings" })
}

local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "ProToggle"
ScreenGui.Parent = game:GetService("CoreGui")
ScreenGui.ResetOnSpawn = false
ScreenGui.DisplayOrder = 9999

local Frame = Instance.new("Frame")
Frame.Parent = ScreenGui
Frame.BackgroundColor3 = Color3.fromRGB(10, 10, 15)
Frame.BackgroundTransparency = 0.45
Frame.Position = UDim2.new(0, 15, 0.5, -15)
Frame.Size = UDim2.new(0, 32, 0, 32)
Frame.Active = true
Frame.Draggable = true

local UICorner = Instance.new("UICorner")
UICorner.CornerRadius = UDim.new(0, 6)
UICorner.Parent = Frame

local TextLabel = Instance.new("TextLabel")
TextLabel.Parent = Frame
TextLabel.Size = UDim2.new(1, 0, 1, 0)
TextLabel.BackgroundTransparency = 1
TextLabel.Text = "Pro"
TextLabel.TextColor3 = Color3.fromRGB(0, 255, 180)
TextLabel.TextSize = 12
TextLabel.Font = Enum.Font.GothamBlack
TextLabel.TextStrokeTransparency = 0.8
TextLabel.TextStrokeColor3 = Color3.fromRGB(0, 255, 180)

local UIStroke = Instance.new("UIStroke")
UIStroke.Color = Color3.fromRGB(0, 255, 180)
UIStroke.Thickness = 1.5
UIStroke.Transparency = 0.3
UIStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
UIStroke.Parent = Frame

local UIGradient = Instance.new("UIGradient")
UIGradient.Color = ColorSequence.new{
    ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 255, 200)),
    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(120, 255, 255)),
    ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 255, 200))
}
UIGradient.Rotation = 45
UIGradient.Parent = Frame

local TweenService = game:GetService("TweenService")
local tweenInfo = TweenInfo.new(0.3, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

Frame.MouseEnter:Connect(function()
    TweenService:Create(Frame, tweenInfo, {Size = UDim2.new(0, 38, 0, 38)}):Play()
    TweenService:Create(UIStroke, tweenInfo, {Thickness = 3, Transparency = 0}):Play()
end)

Frame.MouseLeave:Connect(function()
    TweenService:Create(Frame, tweenInfo, {Size = UDim2.new(0, 32, 0, 32)}):Play()
    TweenService:Create(UIStroke, tweenInfo, {Thickness = 1.5, Transparency = 0.3}):Play()
end)

Frame.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        TweenService:Create(Frame, TweenInfo.new(0.1, Enum.EasingStyle.Quad), {Size = UDim2.new(0, 28, 0, 28)}):Play()
        
        local Sound = Instance.new("Sound")
        Sound.SoundId = "rbxassetid://9119707214"
        Sound.Volume = 0.4
        Sound.Parent = Frame
        Sound:Play()
        game:GetService("Debris"):AddItem(Sound, 1)

        local vim = game:GetService("VirtualInputManager")
        vim:SendKeyEvent(true, Enum.KeyCode.RightControl, false, game)
        task.wait(0.01)
        vim:SendKeyEvent(false, Enum.KeyCode.RightControl, false, game)
    end
end)

Frame.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        TweenService:Create(Frame, TweenInfo.new(0.2, Enum.EasingStyle.Back), {Size = UDim2.new(0, 38, 0, 38)}):Play()
    end
end)

task.spawn(function()
    while true do
        UIGradient.Offset = Vector2.new(-1.2, 0)
        local t = TweenService:Create(UIGradient, TweenInfo.new(3, Enum.EasingStyle.Linear), {Offset = Vector2.new(1.2, 0)})
        t:Play()
        t.Completed:Wait()
    end
end)

Window:OnMinimize(function()
    Frame.Visible = not Frame.Visible
end)

Window:SelectTab(1)
