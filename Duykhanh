local Fluent = loadstring(game:HttpGet("https://github.com/dawid-scripts/Fluent/releases/latest/download/main.lua"))()

local Window = Fluent:CreateWindow({
    Title = "God Hub | Auto Bounty",
    SubTitle = "by DK",
    TabWidth = 160,
    Size = UDim2.fromOffset(580, 420),
    Acrylic = true,
    Theme = "Dark",
    MinimizeKey = Enum.KeyCode.End 
})

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local StartBounty = LocalPlayer.leaderstats["Bounty/Honor"].Value
local StartTime = os.time()

local skillAim, autoV4, fastAttack, walkSpeed = false, false, false, 16
local autoHaki, fakeLag, autoBounty = false, false, false

local Tabs = {
    Bounty = Window:AddTab({ Title = "Auto Bounty", Icon = "target" }),
    PVP = Window:AddTab({ Title = "PVP Combat", Icon = "crosshair" }),
    Misc = Window:AddTab({ Title = "Movement", Icon = "zap" })
}

local StatsParagraph = Tabs.Bounty:AddParagraph({
    Title = "Bounty Statistics",
    Content = "Updating..."
})

task.spawn(function()
    while task.wait(1) do
        local CurrentBounty = LocalPlayer.leaderstats["Bounty/Honor"].Value
        local Earned = CurrentBounty - StartBounty
        local Elapsed = os.time() - StartTime
        
        local h = math.floor(Elapsed / 3600)
        local m = math.floor((Elapsed % 3600) / 60)
        local s = Elapsed % 60
        local TimeStr = string.format("%dh:%dm:%ds", h, m, s)
        
        StatsParagraph:SetTitle("Bounty Statistics")
        StatsParagraph:SetDesc(
            "Current Bounty: " .. tostring(CurrentBounty) .. "\n" ..
            "Bounty Earned: " .. tostring(Earned) .. "$\n" ..
            "Total Bounty Earned: " .. tostring(Earned) .. "$\n" ..
            "Client Time Elapsed: " .. TimeStr .. "\n" ..
            "Account Time Elapsed: " .. TimeStr
        )
    end
end)

Tabs.Bounty:AddButton({
    Title = "Next Player",
    Callback = function() end
})

Tabs.Bounty:AddButton({
    Title = "Hop Server",
    Callback = function() 
        game:GetService("TeleportService"):Teleport(game.PlaceId, LocalPlayer)
    end
})

local ScreenGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
local ToggleButton = Instance.new("ImageButton", ScreenGui)

ToggleButton.Size = UDim2.new(0, 60, 0, 60)
ToggleButton.Position = UDim2.new(0.05, 0, 0.15, 0)
ToggleButton.Image = "rbxassetid://138096365922096" 
ToggleButton.BackgroundTransparency = 1 
ToggleButton.Draggable = true
ToggleButton.Active = true

local MenuVisible = true
ToggleButton.MouseButton1Click:Connect(function()
    MenuVisible = not MenuVisible
    local gui = game:GetService("CoreGui"):FindFirstChild("Fluent") or game:GetService("CoreGui"):FindFirstChild("ScreenGui")
    if gui then gui.Enabled = MenuVisible end
end)

Tabs.PVP:AddToggle("AutoBounty", {Title = "Auto Farm Bounty", Default = false}):OnChanged(function(V) autoBounty = V end)
Tabs.PVP:AddToggle("SkillAim", {Title = "Aim Skill (Auto Hit)", Default = false}):OnChanged(function(V) skillAim = V end)
Tabs.PVP:AddToggle("FastAttack", {Title = "Fast Attack Aura", Default = false}):OnChanged(function(V) fastAttack = V end)
Tabs.PVP:AddToggle("AutoV4", {Title = "Auto Activate V4", Default = false}):OnChanged(function(V) autoV4 = V end)

Tabs.Misc:AddSlider("WS", {Title = "Walk Speed", Min = 16, Max = 300, Default = 16, Rounding = 0}):OnChanged(function(V) walkSpeed = V end)
Tabs.Misc:AddToggle("FakeLag", {Title = "Fake Lag", Default = false}):OnChanged(function(V) fakeLag = V end)

Window:SelectTab(1)
