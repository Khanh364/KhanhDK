local function Optimize(v)
    if v:IsA("BasePart") then
        v.Material = Enum.Material.Plastic
        v.Reflectance = 0
    elseif v:IsA("MeshPart") then
        v.TextureID = ""
    elseif v:IsA("Decal") or v:IsA("Texture") then
        v.Transparency = 1
    elseif v:IsA("ParticleEmitter") or v:IsA("Trail") or v:IsA("Smoke") or v:IsA("Fire") or v:IsA("Sparkles") or v:IsA("Explosion") then
        v:Destroy()
    end
end

for _, v in pairs(game:GetDescendants()) do Optimize(v) end
game.DescendantAdded:Connect(Optimize)

