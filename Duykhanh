-- Fruit Sniper
local Mythics = {"Dragon", "Leopard", "Kitsune", "Mammoth", "T-Rex"}
local function FindFruit()
    for _, v in pairs(WS:GetChildren()) do
        if (v:IsA("Tool") or v.Name:find("Fruit")) and (Config.SniperMode == "All" or table.find(Mythics, v.Name)) then
            return v
        end
    end
    return nil
end

