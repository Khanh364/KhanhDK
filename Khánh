repeat task.wait() until game:IsLoaded()

local Config = {
    FastAttack = true,
    AntiStun = true,
    AntiSit = true,
    Aimlock = true,
    Hitbox = true,
    HitboxSize = 60
}

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Workspace = game:GetService("Workspace")

repeat task.wait() until Players.LocalPlayer
local LocalPlayer = Players.LocalPlayer
repeat task.wait() until LocalPlayer.Character

local CombatFramework
pcall(function() CombatFramework = require(LocalPlayer.PlayerScripts.CombatFramework) end)

task.spawn(function()
    while task.wait() do
        if Config.FastAttack and CombatFramework then
            pcall(function()
                local controller = CombatFramework.activeController
                if controller and controller.equipped then
                    controller.attackInterval = 0
                    controller.timeToNextAttack = 0
                    controller.hitboxCreated = false
                    controller.increment = 3
                    controller:attack()
                end
            end)
        end
    end
end)

RunService.Stepped:Connect(function()
    local char = LocalPlayer.Character
    if not char then return end

    local myHRP = char:FindFirstChild("HumanoidRootPart")
    local myHum = char:FindFirstChildOfClass("Humanoid")
    if not myHRP or not myHum then return end

    if Config.AntiSit then
        myHum.Sit = false
        myHum:SetStateEnabled(Enum.HumanoidStateType.Seated, false)
    end

    if Config.AntiStun then
        myHum.PlatformStand = false
        for _, v in ipairs(char:GetChildren()) do
            if v:IsA("BodyVelocity") or v:IsA("BodyPosition") or v:IsA("BodyGyro") then
                v:Destroy()
            end
            if v.Name == "Stun" or v.Name == "Ice" or v.Name == "Bind" then
                v:Destroy()
            end
        end
    end

    local target, minDistance = nil, math.huge

    local function CheckTarget(hrp, hum)
        if hrp and hum and hum.Health > 0 then
            if Config.Hitbox then
                hrp.Size = Vector3.new(Config.HitboxSize, Config.HitboxSize, Config.HitboxSize)
                hrp.Transparency = 0.8
                hrp.CanCollide = false
            end
            if Config.Aimlock then
                local dist = (hrp.Position - myHRP.Position).Magnitude
                if dist < minDistance then
                    minDistance = dist
                    target = hrp
                end
            end
        end
    end

    for _, plr in ipairs(Players:GetPlayers()) do
        if plr ~= LocalPlayer and plr.Character then
            CheckTarget(plr.Character:FindFirstChild("HumanoidRootPart"), plr.Character:FindFirstChild("Humanoid"))
        end
    end

    local enemies = Workspace:FindFirstChild("Enemies")
    if enemies then
        for _, enemy in ipairs(enemies:GetChildren()) do
            CheckTarget(enemy:FindFirstChild("HumanoidRootPart"), enemy:FindFirstChild("Humanoid"))
        end
    end

    if Config.Aimlock and target then
        myHRP.CFrame = CFrame.lookAt(myHRP.Position, Vector3.new(target.Position.X, myHRP.Position.Y, target.Position.Z))
    end
end)
