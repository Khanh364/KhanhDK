local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local TweenService = game:GetService("TweenService")
local VirtualUser = game:GetService("VirtualUser")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

local Config = getgenv().Setting and getgenv().Setting["Aim Skill"] or getgenv().Setting or {
    Enabled = true,
    SilentAim = true,                  -- Bật silent aim (mouse hit hack)
    AutoSpamSkill = true,              -- TỰ ĐỘNG SPAM SKILL khi có target
    AutoDash = true,                   -- TỰ ĐỘNG DASH theo target
    AutoEquipBest = true,              -- Tự equip vũ khí tốt nhất (Melee/Sword/Fruit/Gun)
    AutoSafeZone = true,               -- Tự teleport safe khi low HP
    SafeLowHP = 3000,
    SafeMaxHP = 4500,
    SafeY = 4000,
    AimPart = "Head",
    Prediction = getgenv().Setting and getgenv().Setting["Aim Prediction"] or 0.135,
    Smoothness = 0.28,
    FOV = 450,
    MaxDist = 1500,
    TeamCheck = true,
    VisibleCheck = false,
    AutoAimSkill = true,
    AlwaysAim = true,
    LowHPOnly = true,
    LowHPTrigger = 4500,
    BountyPriority = true,
    MinBounty = 2000000,
    ShowFOV = true,
    FOVColor = Color3.fromRGB(255,0,0),
    FOVThickness = 2,
    FOVTransparency = 0.8,
    AutoPvP = true,
    SpamDelay = 0.15,                  -- Delay giữa các skill spam
}

_G.AimConfig = Config

local Target = nil
local FOVCircle = nil
local SkillKeys = {"Z", "X", "C", "V", "F"}
local IsAimingSkill = false
local PvPMode = false
local Connections = {}

local function CreateFOVCircle()
    if Config.ShowFOV then
        FOVCircle = Drawing.new("Circle")
        FOVCircle.Visible = true
        FOVCircle.Radius = Config.FOV
        FOVCircle.Color = Config.FOVColor
        FOVCircle.Thickness = Config.FOVThickness
        FOVCircle.Transparency = Config.FOVTransparency
        FOVCircle.Filled = false
        FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    end
end

local function GetBounty(player)
    if player.leaderstats and player.leaderstats:FindFirstChild("Bounty") then
        return player.leaderstats.Bounty.Value
    end
    return 0
end

local function GetClosestTarget()
    local closest, closestDist, closestBounty = nil, math.huge, 0
    local mousePos = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    for _, player in pairs(Players:GetPlayers()) do
        if player \~= LocalPlayer and player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character:FindFirstChild(Config.AimPart) then
            local humanoid = player.Character:FindFirstChild("Humanoid")
            if humanoid and humanoid.Health > 0 then
                
                if Config.TeamCheck and player.Team == LocalPlayer.Team then continue end
                if Config.LowHPOnly and humanoid.Health > Config.LowHPTrigger then continue end
                
                local bounty = GetBounty(player)
                if Config.BountyPriority and bounty < Config.MinBounty then continue end
                
                local targetPart = player.Character[Config.AimPart]
                local rootPart = player.Character.HumanoidRootPart
                local dist = (rootPart.Position - (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and LocalPlayer.Character.HumanoidRootPart.Position or Vector3.new())).Magnitude
                if dist > Config.MaxDist then continue end
                
                if Config.VisibleCheck then
                    local rayParams = RaycastParams.new()
                    rayParams.FilterDescendantsInstances = {LocalPlayer.Character}
                    rayParams.FilterType = Enum.RaycastFilterType.Exclude
                    local ray = workspace:Raycast(rootPart.Position, (LocalPlayer.Character.HumanoidRootPart.Position - rootPart.Position).Unit * dist, rayParams)
                    if ray and ray.Instance:IsDescendantOf(player.Character) == false then continue end
                end
                
                local screenPos, onScreen = Camera:WorldToViewportPoint(targetPart.Position)
                local screenDist = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                
                if onScreen and screenDist < Config.FOV then
                    local score = dist + (Config.BountyPriority and (Config.MinBounty - bounty) / 10000 or 0)
                    if score < closestDist then
                        closestDist = score
                        closestBounty = bounty
                        closest = player
                    end
                end
            end
        end
    end
    return closest
end

local function PredictPosition(targetPart)
    local velocity = targetPart.AssemblyLinearVelocity
    local predictTime = Config.Prediction * (LocalPlayer.Character.HumanoidRootPart.Position - targetPart.Position).Magnitude / 200
    return targetPart.Position + velocity * predictTime
end

local function SilentAim(targetPart)
    if not Config.SilentAim then return end
    local predictedPos = PredictPosition(targetPart)
    local mouse = LocalPlayer:GetMouse()
    mouse.Hit = CFrame.new(predictedPos)
end

local function UpdateAim()
    if not Target or not Target.Character or not Target.Character:FindFirstChild(Config.AimPart) then
        Target = nil
        return
    end
    
    local targetPart = Target.Character[Config.AimPart]
    SilentAim(targetPart)
    
    local predictedPos = PredictPosition(targetPart)
    local currentCFrame = Camera.CFrame
    local targetCFrame = CFrame.lookAt(currentCFrame.Position, predictedPos)
    
    Camera.CFrame = currentCFrame:Lerp(targetCFrame, Config.Smoothness)
end

local function AutoDashToTarget()
    if not Config.AutoDash or not Target or not LocalPlayer.Character then return end
    local hrp = LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    local direction = (Target.Character.HumanoidRootPart.Position - hrp.Position).Unit
    hrp.Velocity = direction * 120  -- Dash speed
    
    -- Simulate dash key if needed (C or double tap W)
    VirtualUser:ClickButton1(Vector2.new())  -- Fake click để trigger dash nếu script yêu cầu
end

local function AutoSpamSkill()
    if not Config.AutoSpamSkill or not Target then return end
    
    -- Simulate bấm skill random hoặc theo thứ tự
    for _, key in ipairs(SkillKeys) do
        VirtualUser:Button1Down(Vector2.new())  -- Fake mouse click nếu cần
        keypress(Enum.KeyCode[key])
        task.wait(Config.SpamDelay)
        keyrelease(Enum.KeyCode[key])
    end
end

local function AutoEquipWeapon()
    if not Config.AutoEquipBest or not LocalPlayer.Backpack then return end
    -- Ưu tiên Fruit > Sword > Melee > Gun (có thể chỉnh)
    for _, tool in ipairs(LocalPlayer.Backpack:GetChildren()) do
        if tool:IsA("Tool") and (tool:FindFirstChild("Fruit") or tool.Name:find("Fruit")) then
            tool.Parent = LocalPlayer.Character
            return
        end
    end
    -- Nếu không có fruit, equip melee/sword
    for _, tool in ipairs(LocalPlayer.Backpack:GetChildren()) do
        if tool:IsA("Tool") then
            tool.Parent = LocalPlayer.Character
            break
        end
    end
end

local function AutoSafeZone()
    if not Config.AutoSafeZone or not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("Humanoid") then return end
    local hp = LocalPlayer.Character.Humanoid.Health
    if hp <= Config.SafeLowHP then
        local hrp = LocalPlayer.Character.HumanoidRootPart
        hrp.CFrame = CFrame.new(hrp.Position.X, Config.SafeY, hrp.Position.Z) + Vector3.new(0, 100, 0)  -- Up high safe
    end
end

local function AutoPvPDetect()
    if not Config.AutoPvP then return false end
    PvPMode = (_G.Target and _G.Target.Parent) or (getgenv().Target and getgenv().Target.Parent) or false
    return PvPMode
end

Connections.TargetLoop = RunService.Heartbeat:Connect(function()
    if not Config.Enabled or not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return end
    
    local shouldAim = Config.AlwaysAim or IsAimingSkill or AutoPvPDetect()
    if shouldAim then
        Target = GetClosestTarget()
    end
    
    if Target then
        UpdateAim()
        AutoDashToTarget()
        AutoSpamSkill()
        AutoEquipWeapon()
        AutoSafeZone()
    end
end)

Connections.FOVLoop = RunService.Heartbeat:Connect(function()
    if FOVCircle then
        FOVCircle.Position = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
        FOVCircle.Visible = Config.Enabled and Config.ShowFOV
    end
end)

Connections.Keybind = UserInputService.InputBegan:Connect(function(input)
    local key = input.KeyCode.Name
    if key == "G" then
        Config.Enabled = not Config.Enabled
        print("Full Auto Combat:", Config.Enabled and "BẬT" or "TẮT")
    end
end)

CreateFOVCircle()
print("Full Auto Combat Loaded! | G = Toggle | Auto Aim + Spam + Dash + Safe + Equip")

_G.AimCleanup = function()
    for _, conn in pairs(Connections) do
        if conn then conn:Disconnect() end
    end
    if FOVCircle then FOVCircle:Remove() end
    print("Full Auto Cleanup!")
end
