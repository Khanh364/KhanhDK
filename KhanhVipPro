local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Mouse = LocalPlayer:GetMouse()
local RunService = game:GetService("RunService")
local Lighting = game:GetService("Lighting")
local Terrain = game:GetService("Workspace").Terrain
local UserInputService = game:GetService("UserInputService")

local AimEnabled = true
local FOV_Radius = 150

local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 1
FOVCircle.NumSides = 100
FOVCircle.Radius = FOV_Radius
FOVCircle.Visible = true
FOVCircle.Color = Color3.fromRGB(0, 255, 255)

local function BuffFPS()
    Terrain.WaterWaveSize = 0
    Terrain.WaterWaveSpeed = 0
    Terrain.WaterReflectance = 0
    Terrain.WaterTransparency = 0
    Lighting.GlobalShadows = false
    for _, v in pairs(Lighting:GetChildren()) do
        if v:IsA("PostEffect") then v.Enabled = false end
    end
    for _, v in pairs(game:GetService("Workspace"):GetDescendants()) do
        if v:IsA("Texture") or v:IsA("Decal") then
            v:Destroy()
        elseif v:IsA("BasePart") and not v:IsA("MeshPart") then
            v.Material = Enum.Material.Plastic
            v.Reflectance = 0
        end
    end
end

local function getClosestTargetInFOV()
    local closestTarget = nil
    local shortestDistance = math.huge
    local mousePos = UserInputService:GetMouseLocation()
    for _, v in pairs(game:GetService("Workspace").Enemies:GetChildren()) do
        if v:FindFirstChild("HumanoidRootPart") and v:FindFirstChild("Humanoid") and v.Humanoid.Health > 0 then
            local screenPos, onScreen = game:GetService("Workspace").CurrentCamera:WorldToViewportPoint(v.HumanoidRootPart.Position)
            if onScreen then
                local mag = (Vector2.new(screenPos.X, screenPos.Y) - mousePos).Magnitude
                if mag < FOV_Radius and mag < shortestDistance then
                    closestTarget = v
                    shortestDistance = mag
                end
            end
        end
    end
    return closestTarget
end

BuffFPS()

RunService.RenderStepped:Connect(function()
    FOVCircle.Position = UserInputService:GetMouseLocation()
    if AimEnabled then
        local target = getClosestTargetInFOV()
        if target and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local pos = target.HumanoidRootPart.Position
            local lookAt = Vector3.new(pos.X, LocalPlayer.Character.HumanoidRootPart.Position.Y, pos.Z)
            LocalPlayer.Character.HumanoidRootPart.CFrame = CFrame.new(LocalPlayer.Character.HumanoidRootPart.Position, lookAt)
        end
    end
end)

local old; old = hookmetamethod(game, "__index", function(self, index)
    if not checkcaller() and self == Mouse and (index == "Hit" or index == "Target") and AimEnabled then
        local target = getClosestTargetInFOV()
        if target then
            return (index == "Hit" and target.HumanoidRootPart.CFrame or target.HumanoidRootPart)
        end
    end
    return old(self, index)
end)
